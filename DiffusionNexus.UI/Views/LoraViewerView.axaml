<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             xmlns:browser="using:DiffusionNexus.UI.Views.CivitaiBrowser"
             xmlns:controls="using:DiffusionNexus.UI.Views.Controls"
             xmlns:air="using:Avalonia.Controls"
             xmlns:al="using:Avalonia.Layout"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.LoraViewerView"
             x:DataType="vm:LoraViewerViewModel">

  <Design.DataContext>
    <vm:LoraViewerViewModel/>
  </Design.DataContext>

  <TabControl Padding="0">
    <TabItem Header="Installed">
      <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                Padding="16,12"
                BorderBrush="#333"
                BorderThickness="0,0,0,1">

          <WrapPanel Orientation="Horizontal">

            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search models..."
                     Width="300"
                     VerticalAlignment="Center"
                     Margin="0,4,12,4"/>

            <StackPanel Orientation="Horizontal" Spacing="6"
                        VerticalAlignment="Center"
                        Margin="0,4,12,4">
              <TextBlock Text="Filter"
                         VerticalAlignment="Center"
                         Opacity="0.7"/>
              <Button VerticalAlignment="Center"
                      Padding="8,6"
                      ToolTip.Tip="Filter by base model">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="&#x25BD;" FontSize="14"
                             IsVisible="{Binding !IsBaseModelFilterActive}"
                             Foreground="#AAAAAA"/>
                  <TextBlock Text="&#x25BD;" FontSize="14"
                             IsVisible="{Binding IsBaseModelFilterActive}"
                             Foreground="#FF4444"/>
                  <TextBlock Text="{Binding ActiveBaseModelFilterCount}"
                             IsVisible="{Binding IsBaseModelFilterActive}"
                             Foreground="#FF4444"
                             FontSize="11"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                  <Flyout Placement="BottomEdgeAlignedLeft"
                          ShowMode="TransientWithDismissOnPointerMoveAway">
                    <Border Background="#1E1E1E"
                            BorderBrush="#444"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8"
                            MinWidth="200"
                            MaxHeight="400">
                      <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="Filter by base model"
                                   FontWeight="SemiBold"
                                   Margin="4,0,4,8"
                                   Opacity="0.7"/>

                        <Button Grid.Row="1"
                                Content="Clear all"
                                Command="{Binding ClearBaseModelFiltersCommand}"
                                IsVisible="{Binding IsBaseModelFilterActive}"
                                Padding="4,2"
                                Margin="4,0,4,8"
                                FontSize="11"
                                HorizontalAlignment="Left"/>

                        <ScrollViewer Grid.Row="2"
                                      MaxHeight="340"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                          <ItemsControl ItemsSource="{Binding AvailableBaseModels}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Spacing="2"/>
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:BaseModelFilterItem">
                                <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Left"
                                              Padding="8,6"
                                              Background="Transparent"
                                              BorderThickness="1"
                                              BorderBrush="#333"
                                              CornerRadius="4">
                                  <TextBlock Text="{Binding BaseModelRaw}"
                                             FontSize="13"/>
                                </ToggleButton>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                      </Grid>
                    </Border>
                  </Flyout>
                </Button.Flyout>
              </Button>
            </StackPanel>

            <CheckBox Content="Show NSFW"
                      IsChecked="{Binding ShowNsfw, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,4,12,4"/>

            <Button Command="{Binding ResetFiltersCommand}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Reset all filters"
                    Margin="0,4,12,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x21BA;" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Reset" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <StackPanel Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center"
                        Margin="0,4,12,4">
              <TextBlock Text="Sort"
                         VerticalAlignment="Center"
                         Opacity="0.7"/>
              <ComboBox ItemsSource="{Binding SortOptions}"
                        SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}"
                        MinWidth="120"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Choose how installed models are sorted"/>
              <ToggleButton IsChecked="{Binding SortDescending, Mode=TwoWay}"
                            VerticalAlignment="Center"
                            Padding="8,6"
                            ToolTip.Tip="Toggle ascending / descending">
                <Panel>
                  <!-- Ascending (A→Z / oldest first) when unchecked, descending when checked. -->
                  <TextBlock Text="&#x2191;" FontSize="14"
                             IsVisible="{Binding !SortDescending}"/>
                  <TextBlock Text="&#x2193;" FontSize="14"
                             IsVisible="{Binding SortDescending}"/>
                </Panel>
              </ToggleButton>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center"
                        Margin="0,4,12,4">
              <TextBlock Text="{Binding FilteredModelCount}" FontWeight="SemiBold"/>
              <TextBlock Text="of" Opacity="0.6"/>
              <TextBlock Text="{Binding TotalModelCount}"/>
              <TextBlock Text="models" Opacity="0.6"/>
            </StackPanel>

            <Button Command="{Binding DownloadLoraCommand}"
                    ToolTip.Tip="Download a LoRA from Civitai"
                    VerticalAlignment="Center"
                    Margin="0,4,12,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x2B07;" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Download LoRA" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding RefreshCommand}"
                    ToolTip.Tip="Rescan source folders and reload the model list"
                    VerticalAlignment="Center"
                    Margin="0,4,12,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x21BB;" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding DownloadMissingMetadataCommand}"
                    ToolTip.Tip="Fetch missing metadata from Civitai for already-imported LoRAs"
                    VerticalAlignment="Center"
                    Margin="0,4,12,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x21E9;" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Download Metadata" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

            <Button Command="{Binding ScanDuplicatesCommand}"
                    ToolTip.Tip="Scan all configured LoRA folders for byte-identical files"
                    VerticalAlignment="Center"
                    Margin="0,4,0,4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#x29C9;" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Find Duplicates" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

          </WrapPanel>
        </Border>

        <!-- Main Content: Tiles + Detail Panel (overlay) -->
        <Grid Grid.Row="1">

          <Grid>

            <!-- Tile grid. FilteredTiles holds the FULL filtered set; the ItemsRepeater
                 with a UniformGridLayout virtualizes it, so only the tiles inside the
                 scroll viewport are realized (a 2K+ LoRA library opens instantly and
                 scrolls smoothly). As a container recycles out of view its ModelTileControl
                 detaches, calling Deactivate() on the bound VM to release the decoded
                 thumbnail; scrolling a tile in calls Activate() to load it on demand.
                 Item footprint = 250 wide + 6 margin all round; MinItemHeight leaves a
                 small row gap above the tile's natural height so nothing clips. -->
            <ScrollViewer Padding="16"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">

              <air:ItemsRepeater ItemsSource="{Binding FilteredTiles}"
                                 Margin="0,0,0,40">
                <air:ItemsRepeater.Layout>
                  <al:UniformGridLayout Orientation="Horizontal"
                                        MinItemWidth="262"
                                        MinItemHeight="276"
                                        MinColumnSpacing="0"
                                        MinRowSpacing="0"
                                        ItemsStretch="None"/>
                </air:ItemsRepeater.Layout>
                <air:ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="vm:ModelTileViewModel">
                    <Border Margin="6" Width="250">
                      <controls:ModelTileControl/>
                    </Border>
                  </DataTemplate>
                </air:ItemsRepeater.ItemTemplate>
              </air:ItemsRepeater>

            </ScrollViewer>

            <Border IsVisible="{Binding !FilteredModelCount}"
                    Background="#1A1A1A"
                    CornerRadius="8"
                    Margin="16"
                    Padding="32"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
              <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Background="#333" CornerRadius="12" Padding="24">
                  <TextBlock Text="No Models" FontSize="18" Opacity="0.4" HorizontalAlignment="Center"/>
                </Border>
                <TextBlock Text="No Models Found"
                           FontSize="20"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Add LoRA source folders in Settings, then click Refresh."
                           Opacity="0.6"
                           HorizontalAlignment="Center"/>
                <Button Content="Open Settings"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0"/>
              </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsBusy}"
                    Background="#CC000000">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressBar IsIndeterminate="True" Width="300"/>
                <TextBlock Text="{Binding BusyMessage}"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <Button Content="Cancel"
                        Command="{Binding CancelMetadataDownloadCommand}"
                        IsVisible="{Binding IsCancellable}"
                        HorizontalAlignment="Center"
                        Padding="20,6"
                        ToolTip.Tip="Stop the metadata sync after the current model finishes"/>
              </StackPanel>
            </Border>

          </Grid>

          <Border IsVisible="{Binding IsDetailOpen}"
                  HorizontalAlignment="Right"
                  Width="624">
            <controls:ModelDetailView DataContext="{Binding DetailViewModel}"/>
          </Border>

        </Grid>

        <Border Grid.Row="2"
                Background="#1E1E1E"
                Padding="8,4"
                BorderBrush="#333"
                BorderThickness="0,1,0,0"
                IsVisible="{Binding SyncStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <TextBlock Text="{Binding SyncStatus}"
                     Opacity="0.8"
                     FontSize="12"/>
        </Border>

      </Grid>
    </TabItem>

    <TabItem Header="Browse Civitai">
      <browser:CivitaiBrowserView DataContext="{Binding BrowserViewModel}"/>
    </TabItem>
  </TabControl>
</UserControl>
