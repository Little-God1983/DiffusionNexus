<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DiffusionNexus.UI.Views.Dialogs"
        x:Class="DiffusionNexus.UI.Views.Dialogs.SelectLoraVersionsToDeleteDialog"
        x:DataType="local:SelectLoraVersionsToDeleteDialog"
        Width="520"
        MinHeight="280"
        MaxHeight="600"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E1E">

  <Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto,Auto">

    <!-- Message -->
    <TextBlock Grid.Row="0"
               Text="{Binding Message}"
               TextWrapping="Wrap"
               FontSize="14"
               Margin="0,0,0,16"/>

    <!-- Select All / Clear Selection -->
    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,12">
      <Button Content="Select All"
              Click="OnSelectAllClick"
              Padding="12,4"
              FontSize="12"
              Background="#333333"/>
      <Button Content="Clear Selection"
              Click="OnClearSelectionClick"
              Padding="12,4"
              FontSize="12"
              Background="#333333"/>
    </StackPanel>

    <!-- Version List -->
    <ScrollViewer Grid.Row="2"
                  MaxHeight="320"
                  Margin="0,0,0,16">
      <ItemsControl ItemsSource="{Binding VersionItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="local:LoraVersionDeleteItem">
            <Border Background="#2A2A2A"
                    CornerRadius="6"
                    Padding="12,10"
                    Margin="0,0,0,6"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1">
              <Grid ColumnDefinitions="Auto,*">
                <CheckBox Grid.Column="0"
                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding FileName}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis"
                             ToolTip.Tip="{Binding FileName}"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#0078D4"
                            CornerRadius="3"
                            Padding="6,2">
                      <TextBlock Text="{Binding BaseModelDisplay}"
                                 FontSize="11"
                                 Foreground="White"/>
                    </Border>
                    <TextBlock Text="{Binding DetailText}"
                               FontSize="11"
                               Foreground="#999999"
                               VerticalAlignment="Center"
                               IsVisible="{Binding DetailText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Selection Summary -->
    <TextBlock Grid.Row="3"
               Text="{Binding SelectionSummary}"
               FontSize="12"
               Foreground="#AAAAAA"
               Margin="0,0,0,16"/>

    <!-- Action Buttons -->
    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="Cancel"
              Click="OnCancelClick"
              MinWidth="100"
              Padding="16,8"
              Background="#333333"/>
      <Button Content="Delete Selected"
              Click="OnDeleteClick"
              IsEnabled="{Binding HasSelection}"
              MinWidth="140"
              Padding="16,8"
              Background="#E53935"
              Foreground="White"/>
    </StackPanel>

  </Grid>
</Window>
