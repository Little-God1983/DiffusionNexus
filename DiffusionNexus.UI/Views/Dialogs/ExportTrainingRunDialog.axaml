<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DiffusionNexus.UI.ViewModels"
        x:Class="DiffusionNexus.UI.Views.Dialogs.ExportTrainingRunDialog"
        x:DataType="vm:ExportTrainingRunDialogViewModel"
        Title="Export Training Run"
        Width="600"
        MinHeight="400"
        MaxHeight="750"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">
  <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock Grid.Row="0" Text="{Binding TrainingRunName, StringFormat='Export: {0}'}" FontSize="18" FontWeight="SemiBold" Foreground="#FF6A00" Margin="0,0,0,16"/>
    <StackPanel Grid.Row="1" Spacing="6" Margin="0,0,0,16">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Epochs" FontSize="14" FontWeight="SemiBold" Foreground="#4CAF50" VerticalAlignment="Center"/>
          <Border Background="#4CAF50" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedEpochCount}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
          </Border>
          <TextBlock Text="{Binding Epochs.Count, StringFormat='of {0}'}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
        </StackPanel>
        <Button Grid.Column="1" Content="All" Command="{Binding SelectAllEpochsCommand}" Padding="8,3" FontSize="11" Margin="0,0,4,0"/>
        <Button Grid.Column="2" Content="None" Command="{Binding ClearAllEpochsCommand}" Padding="8,3" FontSize="11"/>
      </Grid>
      <TextBlock Text="No epoch files found" FontSize="12" Opacity="0.5" Margin="4,4" IsVisible="{Binding !Epochs.Count}"/>
      <Border Background="#1E1E1E" CornerRadius="6" Padding="4" MaxHeight="160" IsVisible="{Binding Epochs.Count}" BorderBrush="#333" BorderThickness="1">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Epochs}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SelectableExportItem">
                <CheckBox IsChecked="{Binding IsSelected}" Margin="4,2" Padding="8,4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Opacity="0.5" VerticalAlignment="Center" IsVisible="{Binding HasSize}"/>
                  </StackPanel>
                </CheckBox>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </StackPanel>
    <StackPanel Grid.Row="2" Spacing="6" Margin="0,0,0,16">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Presentation Images" FontSize="14" FontWeight="SemiBold" Foreground="#2196F3" VerticalAlignment="Center"/>
          <Border Background="#2196F3" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
            <TextBlock Text="{Binding SelectedImageCount}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
          </Border>
          <TextBlock Text="{Binding Images.Count, StringFormat='of {0}'}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
        </StackPanel>
        <Button Grid.Column="1" Content="All" Command="{Binding SelectAllImagesCommand}" Padding="8,3" FontSize="11" Margin="0,0,4,0"/>
        <Button Grid.Column="2" Content="None" Command="{Binding ClearAllImagesCommand}" Padding="8,3" FontSize="11"/>
      </Grid>
      <TextBlock Text="No presentation images found" FontSize="12" Opacity="0.5" Margin="4,4" IsVisible="{Binding !Images.Count}"/>
      <Border Background="#1E1E1E" CornerRadius="6" Padding="4" MaxHeight="160" IsVisible="{Binding Images.Count}" BorderBrush="#333" BorderThickness="1">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Images}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SelectableExportItem">
                <CheckBox IsChecked="{Binding IsSelected}" Margin="4,2" Padding="8,4">
                  <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                </CheckBox>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </StackPanel>
    <StackPanel Grid.Row="3" Spacing="4" Margin="0,0,0,20">
      <TextBlock Text="Model Card" FontSize="14" FontWeight="SemiBold" Foreground="#FF9800"/>
      <CheckBox IsChecked="{Binding IncludeModelCard}" Margin="0,4" Padding="8,4">
        <StackPanel Spacing="2">
          <TextBlock Text="Include README.md" FontSize="12"/>
          <TextBlock Text="Trigger words, tags, training parameters, and description in readable Markdown" FontSize="11" Opacity="0.5"/>
        </StackPanel>
      </CheckBox>
    </StackPanel>
    <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="6" Padding="12,8" Margin="0,0,0,16" BorderBrush="#333" BorderThickness="1">
      <Grid ColumnDefinitions="Auto,*">
        <TextBlock Grid.Column="0" Text="Will export:" FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBlock Grid.Column="1" Text="{Binding ExportSummary}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
      </Grid>
    </Border>
    <Grid Grid.Row="5" ColumnDefinitions="*,Auto,Auto">
      <Border Grid.Column="0"/>
      <Button Grid.Column="1" Content="Cancel" Click="OnCancelClick" Padding="16,8" Margin="0,0,8,0"/>
      <Button Grid.Column="2" Content="Export..." Click="OnExportClick" Padding="16,8" Background="#FF6A00" Foreground="White" FontWeight="SemiBold" IsEnabled="{Binding HasSelection}"/>
    </Grid>
  </Grid>
</Window>
