<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DiffusionNexus.UI.ViewModels"
        x:Class="DiffusionNexus.UI.Views.Dialogs.UnifiedExportDialog"
        x:DataType="vm:UnifiedExportDialogViewModel"
        Width="680"
        MaxHeight="800"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#252526">

  <Grid Margin="24" RowDefinitions="Auto,*,Auto,Auto">

    <!-- Title -->
    <TextBlock Grid.Row="0"
               Text="{Binding DialogTitle}"
               FontSize="20"
               FontWeight="SemiBold"
               Foreground="#D4A574"
               Margin="0,0,0,16"/>

    <!-- Tabbed content -->
    <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Padding="0" Margin="0,0,0,12">

      <!-- ═══ Dataset Tab ═══ -->
      <TabItem Header="Dataset" IsVisible="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="480">
          <StackPanel Margin="12" Spacing="12" DataContext="{Binding DatasetExport}">

            <!-- Export Format -->
            <StackPanel>
              <TextBlock Text="Export Format" FontWeight="SemiBold" Margin="0,0,0,6"/>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Single Files" IsChecked="{Binding IsSingleFilesExport}" GroupName="ExportType"/>
                <RadioButton Content="ZIP Archive" IsChecked="{Binding IsZipExport}" GroupName="ExportType"/>
              </StackPanel>

              <!-- AI Toolkit option -->
              <StackPanel IsVisible="{Binding HasAIToolkitInstances}" Margin="0,8,0,0">
                <RadioButton IsChecked="{Binding IsAIToolkitExport}" GroupName="ExportType">
                  <TextBlock Text="Export to AI-Toolkit"/>
                </RadioButton>
                <ComboBox ItemsSource="{Binding AIToolkitInstances}"
                          SelectedItem="{Binding SelectedAIToolkitInstance}"
                          IsVisible="{Binding IsAIToolkitExport}"
                          Margin="24,4,0,0" MinWidth="250" HorizontalAlignment="Left">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel IsVisible="{Binding IsAIToolkitExport}" Margin="24,6,0,0">
                  <TextBlock Text="Folder Name" Opacity="0.7" Margin="0,0,0,2"/>
                  <TextBox Text="{Binding AIToolkitFolderName}" Watermark="Dataset folder name"
                           MinWidth="250" HorizontalAlignment="Left"/>
                  <Border IsVisible="{Binding AIToolkitFolderExists}"
                          Background="#7D5C2D" CornerRadius="6" Padding="10,8" Margin="0,6,0,0">
                    <StackPanel Spacing="6">
                      <TextBlock Text="{Binding AIToolkitFolderExistsText}" FontWeight="SemiBold" Foreground="#FFD180"/>
                      <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton IsChecked="{Binding IsMergeMode}" GroupName="ConflictMode">
                          <TextBlock Text="Merge"/>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsOverwriteMode}" GroupName="ConflictMode">
                          <TextBlock Text="Overwrite"/>
                        </RadioButton>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </StackPanel>

              <!-- Include in Export -->
              <TextBlock Text="Include in Export" FontWeight="SemiBold" Margin="0,12,0,6"/>
              <CheckBox IsChecked="{Binding ExportProductionReady}" Margin="0,2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10" Fill="#4CAF50" VerticalAlignment="Center"/>
                  <TextBlock Text="Production Ready" Foreground="#4CAF50"/>
                  <TextBlock Text="{Binding ProductionReadyCount, StringFormat='({0})'}" Opacity="0.7"/>
                </StackPanel>
              </CheckBox>
              <CheckBox IsChecked="{Binding ExportUnrated}" Margin="0,2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10" Fill="#888" VerticalAlignment="Center"/>
                  <TextBlock Text="Unrated"/>
                  <TextBlock Text="{Binding UnratedCount, StringFormat='({0})'}" Opacity="0.7"/>
                </StackPanel>
              </CheckBox>
              <CheckBox IsChecked="{Binding ExportTrash}" Margin="0,2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Ellipse Width="10" Height="10" Fill="#F44336" VerticalAlignment="Center"/>
                  <TextBlock Text="Trash" Foreground="#F44336"/>
                  <TextBlock Text="{Binding TrashCount, StringFormat='({0})'}" Opacity="0.7"/>
                </StackPanel>
              </CheckBox>

              <!-- Preview count -->
              <Border Background="#2D7D46" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                      IsVisible="{Binding CanExport}">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="Will be exported:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding ToExportText}" FontWeight="Bold" FontSize="14"/>
                </Grid>
              </Border>
              <Border Background="#7D2D2D" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                      IsVisible="{Binding !CanExport}">
                <TextBlock Text="Select at least one category to export." HorizontalAlignment="Center" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- ═══ Training Runs Tab ═══ -->
      <TabItem Header="Training Runs" IsVisible="{Binding HasTrainingRuns}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="480">
          <StackPanel Margin="12" Spacing="10">

            <!-- Select all / clear -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Select All" Command="{Binding SelectAllRunsCommand}" Padding="8,4" FontSize="12"/>
              <Button Content="Clear All" Command="{Binding ClearAllRunsCommand}" Padding="8,4" FontSize="12"/>
              <TextBlock Text="{Binding SelectedRunCount, StringFormat='{}{0} selected'}"
                         FontSize="12" Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Run list -->
            <ItemsControl ItemsSource="{Binding TrainingRuns}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExportableTrainingRun">
                  <Border Background="#2A2A2A" CornerRadius="6" Padding="10" Margin="0,0,0,6"
                          BorderBrush="#444" BorderThickness="1">
                    <StackPanel Spacing="6">
                      <!-- Run header: checkbox + name + summary + expand -->
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                          <TextBlock Text="{Binding ItemSummary}" FontSize="11" Opacity="0.6"/>
                        </StackPanel>
                        <CheckBox Grid.Column="2" IsChecked="{Binding IncludeModelCard}"
                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                  ToolTip.Tip="Include model card (README.md)">
                          <TextBlock Text="Model Card" FontSize="11"/>
                        </CheckBox>
                        <Button Grid.Column="3" Content="Details" Command="{Binding ToggleExpandedCommand}"
                                Padding="6,3" FontSize="11" Background="#80444444" CornerRadius="3"
                                VerticalAlignment="Center"/>
                      </Grid>

                      <!-- Expandable detail: epochs + images -->
                      <StackPanel IsVisible="{Binding IsExpanded}" Spacing="8" Margin="28,4,0,0">
                        <!-- Epochs -->
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding SelectedEpochCount, StringFormat='Epochs ({0} selected)'}"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="All" Command="{Binding SelectAllEpochsCommand}"
                                    Padding="6,2" FontSize="11" Margin="0,0,4,0"/>
                            <Button Grid.Column="2" Content="None" Command="{Binding ClearAllEpochsCommand}"
                                    Padding="6,2" FontSize="11"/>
                          </Grid>
                          <ItemsControl ItemsSource="{Binding Epochs}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:SelectableExportItem">
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,1">
                                  <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="12"/>
                                    <TextBlock Text="{Binding SizeDisplay}" FontSize="11" Opacity="0.5"
                                               IsVisible="{Binding HasSize}"/>
                                  </StackPanel>
                                </CheckBox>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>

                        <!-- Images -->
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding SelectedImageCount, StringFormat='Images ({0} selected)'}"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="All" Command="{Binding SelectAllImagesCommand}"
                                    Padding="6,2" FontSize="11" Margin="0,0,4,0"/>
                            <Button Grid.Column="2" Content="None" Command="{Binding ClearAllImagesCommand}"
                                    Padding="6,2" FontSize="11"/>
                          </Grid>
                          <ItemsControl ItemsSource="{Binding Images}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:SelectableExportItem">
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,1">
                                  <TextBlock Text="{Binding Name}" FontSize="12"/>
                                </CheckBox>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <!-- Summary bar -->
    <Border Grid.Row="2" Background="#333" CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
      <TextBlock Text="{Binding ExportSummary}" FontSize="13" Opacity="0.8" HorizontalAlignment="Center"/>
    </Border>

    <!-- Buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Cancel" Width="100" Click="OnCancelClick"/>
      <Button Content="Export..." Width="100" Background="#2D7D46" IsEnabled="{Binding CanExport}" Click="OnExportClick"/>
    </StackPanel>

  </Grid>
</Window>
