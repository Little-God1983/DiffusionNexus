<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:DiffusionNexus.UI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="480"
        x:Class="DiffusionNexus.UI.Views.Dialogs.CaptioningDownloadOptionsDialog"
        x:DataType="vm:CaptioningDownloadOptionsViewModel"
        Title="Download Options"
        Width="560" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E">

    <Window.Styles>
        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="#0088CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.primary-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#009AE0"/>
        </Style>
        <Style Selector="Button.primary-btn:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style Selector="Button.cancel-btn">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        <Style Selector="Button.cancel-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#444444"/>
        </Style>
        <Style Selector="TextBlock.section-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
    </Window.Styles>

    <Grid Margin="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto">

        <TextBlock Grid.Row="0"
                   Text="{Binding ModelDisplayName, StringFormat='Download — {0}'}"
                   FontSize="16" FontWeight="Bold" Foreground="White"
                   TextWrapping="Wrap"/>

        <!-- VRAM tier picker -->
        <TextBlock Grid.Row="1" Text="GPU VRAM" Classes="section-label"/>
        <ComboBox Grid.Row="2"
                  ItemsSource="{Binding VramTiers}"
                  SelectedItem="{Binding SelectedVramGb}"
                  HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:Int32">
                    <TextBlock Text="{Binding StringFormat='{}{0} GB'}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Grid.Row="3"
                   Text="{Binding RequiredSpaceLabel}"
                   FontSize="12" Foreground="#999999"
                   Margin="0,6,0,0"/>

        <!-- Destination picker -->
        <TextBlock Grid.Row="4" Text="Save to" Classes="section-label"/>
        <ListBox Grid.Row="5"
                 ItemsSource="{Binding Destinations}"
                 SelectedItem="{Binding SelectedDestination}"
                 Background="#2A2A2A"
                 BorderBrush="#3D3D3D" BorderThickness="1"
                 CornerRadius="4"
                 Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:DestinationOptionViewModel">
                    <StackPanel Spacing="2" Margin="4,6">
                        <TextBlock Text="{Binding Label}"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="{Binding FreeBytesLabel}"
                                       FontSize="11" Foreground="#999999"/>
                            <TextBlock Text="{Binding SpaceCheckLabel}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{Binding SpaceCheckColor}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="6"
                   Text="{Binding InsufficientSpaceWarning}"
                   FontSize="12" Foreground="#F44336"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"/>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button Classes="cancel-btn" Content="Cancel" Click="OnCancel"/>
            <Button Classes="primary-btn"
                    Content="Download"
                    IsEnabled="{Binding CanConfirm}"
                    Click="OnConfirm"/>
        </StackPanel>
    </Grid>
</Window>
