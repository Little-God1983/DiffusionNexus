<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:DiffusionNexus.UI.Views.Dialogs"
        x:Class="DiffusionNexus.UI.Views.Dialogs.CivitaiTokenDialog"
        x:DataType="local:CivitaiTokenDialog"
        Title="Civitai API Token Required"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#2D2D30">

  <StackPanel Margin="24" Spacing="16">

    <!-- Help heading with explicit line breaks -->
    <TextBlock FontSize="18"
               FontWeight="Bold"
               Foreground="White">
      <Run Text="This action requires a Civitai API token"/>
      <LineBreak/>
      <Run Text="to download content from Civitai."/>
      <LineBreak/>
      <LineBreak/>
      <Run Text="How do I get an API token/key?"/>
    </TextBlock>

    <!-- Instructions -->
    <StackPanel Spacing="8">
      <TextBlock TextWrapping="Wrap"
                 Foreground="#CCCCCC"
                 FontSize="14"
                 LineHeight="22"
                 Text="1. Create an API token from your user account page:"/>

      <TextBlock TextWrapping="Wrap"
                 Foreground="#66AAFF"
                 FontSize="14"
                 Cursor="Hand"
                 TextDecorations="Underline"
                 PointerPressed="OnCivitaiLinkClick"
                 Margin="16,0,0,0"
                 Text="https://civitai.com/user/account"/>

      <TextBlock TextWrapping="Wrap"
                 Foreground="#CCCCCC"
                 FontSize="14"
                 LineHeight="22"
                 Text="2. Copy the token and paste it in the field below (it will be encrypted)."/>
    </StackPanel>

    <!-- Reference image -->
    <Border Background="#1A1A1A"
            CornerRadius="6"
            Padding="8"
            HorizontalAlignment="Center">
      <Image Source="avares://DiffusionNexus.UI/Assets/LoraViewer/API-Key.png"
             MaxWidth="480"
             Stretch="Uniform"/>
    </Border>

    <!-- Token input -->
    <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,0">
      <TextBlock Grid.Column="0"
                 Text="API Token:"
                 Foreground="White"
                 FontWeight="SemiBold"
                 VerticalAlignment="Center"
                 Margin="0,0,12,0"/>
      <TextBox Grid.Column="1"
               Name="TokenTextBox"
               Text="{Binding TokenText}"
               Watermark="Paste your Civitai API token here..."
               PasswordChar="*"
               FontSize="14"
               Padding="8,6"/>
    </Grid>

    <!-- Validation status -->
    <StackPanel Name="ValidationPanel"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Center"
                IsVisible="False">
      <ProgressBar Name="ValidationSpinner"
                   IsIndeterminate="True"
                   Width="80"
                   Height="4"/>
      <TextBlock Name="ValidationMessage"
                 Foreground="#CCCCCC"
                 FontSize="13"
                 VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Error message -->
    <TextBlock Name="ErrorMessage"
               Foreground="#FF6666"
               FontSize="13"
               TextWrapping="Wrap"
               HorizontalAlignment="Center"
               IsVisible="False"/>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button Name="CancelButton"
              Content="Cancel"
              Width="90"
              Padding="8,6"
              Click="OnCancelClick"/>
      <Button Name="SaveButton"
              Content="Save and Continue"
              Width="140"
              Padding="8,6"
              IsDefault="True"
              Background="#4CAF50"
              Foreground="White"
              FontWeight="SemiBold"
              Click="OnSaveClick"/>
    </StackPanel>

  </StackPanel>
</Window>
