<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:DiffusionNexus.UI.Views.Controls"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             x:Class="DiffusionNexus.UI.Views.Controls.DatasetVersionSelectorControl"
             x:DataType="local:DatasetVersionSelectorControl">

  <StackPanel Spacing="6" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Dataset:" VerticalAlignment="Center" Opacity="0.7" MinWidth="50"/>
      <ComboBox x:Name="DatasetComboBox"
                ItemsSource="{Binding Datasets, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}}"
                SelectedItem="{Binding SelectedDataset, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}, Mode=TwoWay}"
                IsEditable="{Binding IsDatasetSearchable, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}}"
                MinWidth="180" MaxWidth="250"
                PlaceholderText="{Binding DatasetPlaceholderText, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:DatasetCardViewModel">
            <TextBlock Text="{Binding Name}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Version:" VerticalAlignment="Center" Opacity="0.7" MinWidth="50"/>
      <ComboBox x:Name="VersionComboBox"
                ItemsSource="{Binding VersionItems, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}}"
                SelectedItem="{Binding SelectedVersion, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}, Mode=TwoWay}"
                MinWidth="120"
                IsEnabled="{Binding SelectedDataset, RelativeSource={RelativeSource AncestorType=local:DatasetVersionSelectorControl}, Converter={x:Static ObjectConverters.IsNotNull}}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:EditorVersionItem">
            <TextBlock Text="{Binding DisplayText}" Foreground="#4CAF50"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>
  </StackPanel>
</UserControl>
