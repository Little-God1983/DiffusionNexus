<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="40"
             x:Class="DiffusionNexus.UI.Views.Controls.ResourceMonitorView"
             x:DataType="vm:ResourceMonitorViewModel">

  <Design.DataContext>
    <vm:ResourceMonitorViewModel/>
  </Design.DataContext>

  <Border Background="#252526" CornerRadius="6" BorderBrush="#3A3A3A" BorderThickness="1" Padding="10,5">
    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">

      <!-- GPU name -->
      <TextBlock Text="{Binding GpuName}" Foreground="#DDD" FontSize="11" FontWeight="SemiBold"
                 VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding GpuName}"/>

      <!-- VRAM gauge -->
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                  IsVisible="{Binding IsGpuAvailable}">
        <TextBlock Text="VRAM" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
        <ProgressBar Minimum="0" Maximum="100" Value="{Binding VramPercent}"
                     Width="130" Height="10" Foreground="#0E9C6A" VerticalAlignment="Center"
                     ToolTip.Tip="GPU memory used"/>
        <TextBlock Text="{Binding VramText}" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- GPU utilization -->
      <TextBlock IsVisible="{Binding IsGpuAvailable}" Foreground="#888" FontSize="11"
                 VerticalAlignment="Center" ToolTip.Tip="GPU utilization">
        <Run Text="GPU"/><Run Text=" "/><Run Text="{Binding GpuUtilPercent}"/><Run Text="%"/>
      </TextBlock>

      <!-- GPU unavailable message -->
      <TextBlock Text="{Binding ErrorText}" Foreground="#C8A03A" FontSize="11" VerticalAlignment="Center"
                 IsVisible="{Binding !IsGpuAvailable}" MaxWidth="240" TextTrimming="CharacterEllipsis"
                 ToolTip.Tip="{Binding ErrorText}"/>

      <!-- RAM gauge -->
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock Text="RAM" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
        <ProgressBar Minimum="0" Maximum="100" Value="{Binding RamPercent}"
                     Width="130" Height="10" Foreground="#3B7DD8" VerticalAlignment="Center"
                     ToolTip.Tip="System memory used"/>
        <TextBlock Text="{Binding RamText}" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Manual refresh -->
      <Button Command="{Binding RefreshCommand}" Content="↻" FontSize="13"
              Padding="6,0" MinWidth="0" Background="Transparent" BorderThickness="0"
              Foreground="#AAAAAA" VerticalAlignment="Center"
              ToolTip.Tip="Refresh now (auto-refreshes every 2s while visible)"/>
    </StackPanel>
  </Border>
</UserControl>
