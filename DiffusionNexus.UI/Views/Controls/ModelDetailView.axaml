<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.Controls.ModelDetailView"
             x:DataType="vm:ModelDetailViewModel">

  <Design.DataContext>
    <vm:ModelDetailViewModel/>
  </Design.DataContext>

  <UserControl.Styles>
    <!-- Downloaded version tabs: blue -->
    <Style Selector="ToggleButton.downloaded">
      <Setter Property="Background" Value="#003366"/>
      <Setter Property="Foreground" Value="#66AAFF"/>
      <Setter Property="BorderBrush" Value="#004488"/>
    </Style>
    <Style Selector="ToggleButton.downloaded:pointerover">
      <Setter Property="Background" Value="#004477"/>
    </Style>
    <Style Selector="ToggleButton.downloaded:checked">
      <Setter Property="Background" Value="#0066CC"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="BorderBrush" Value="#3399FF"/>
    </Style>

    <!-- Not-downloaded version tabs: yellow -->
    <Style Selector="ToggleButton.notdownloaded">
      <Setter Property="Background" Value="#554400"/>
      <Setter Property="Foreground" Value="#FFCC00"/>
      <Setter Property="BorderBrush" Value="#776600"/>
    </Style>
    <Style Selector="ToggleButton.notdownloaded:pointerover">
      <Setter Property="Background" Value="#665500"/>
    </Style>
    <Style Selector="ToggleButton.notdownloaded:checked">
      <Setter Property="Background" Value="#887700"/>
      <Setter Property="Foreground" Value="#FFE066"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="BorderBrush" Value="#FFCC00"/>
    </Style>
  </UserControl.Styles>

  <Border Background="#1E1E1E"
          BorderBrush="#333"
          BorderThickness="1,0,0,0">

    <Grid RowDefinitions="Auto,*">

      <!-- Header: Model Name + Close Button -->
      <Border Grid.Row="0"
              Background="#252525"
              Padding="16,12"
              BorderBrush="#333"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding ModelName}"
                     FontSize="18"
                     FontWeight="Bold"
                     Foreground="White"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1"
                  Content="&#x2715;"
                  Command="{Binding CloseCommand}"
                  Background="Transparent"
                  Foreground="#888"
                  FontSize="16"
                  Padding="8,4"
                  VerticalAlignment="Top"
                  ToolTip.Tip="Close detail panel"/>
        </Grid>
      </Border>

      <!-- Scrollable Content -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="0">

          <!-- Version Tabs -->
          <Border Background="#252525"
                  Padding="8"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
              <TextBlock Text="Versions"
                         FontSize="11"
                         Opacity="0.5"
                         Margin="4,0,0,4"/>
              <ItemsControl ItemsSource="{Binding VersionTabs}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CivitaiVersionTabItem">
                    <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Command="{Binding SelectCommand}"
                                  ToolTip.Tip="{Binding BaseModel}"
                                  Classes.downloaded="{Binding IsDownloaded}"
                                  Classes.notdownloaded="{Binding !IsDownloaded}"
                                  Margin="2"
                                  Padding="10,6"
                                  FontSize="12"
                                  CornerRadius="4"
                                  MinWidth="60"
                                  BorderThickness="1">
                      <TextBlock Text="{Binding Label}"
                                 TextTrimming="CharacterEllipsis"
                                 MaxWidth="160"/>
                    </ToggleButton>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Download Button (visible when a non-downloaded version is selected) -->
          <Border Padding="16,8,16,4"
                  IsVisible="{Binding SelectedVersionTab.IsDownloaded, Converter={x:Static BoolConverters.Not}, FallbackValue=False}">
            <Button Content="Download This Version"
                    Command="{Binding DownloadSelectedVersionCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="12,10"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="#FFCC00"
                    Foreground="#1E1E1E"
                    CornerRadius="4"/>
          </Border>

          <!-- Image + Metadata Row -->
          <Border Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">

              <!-- Thumbnail -->
              <Border Grid.Column="0"
                      Width="180"
                      Height="220"
                      Background="#1A1A1A"
                      CornerRadius="4"
                      ClipToBounds="True"
                      Margin="0,0,16,0">
                <Grid>
                  <Image Source="{Binding ThumbnailImage}"
                         Stretch="UniformToFill"
                         IsVisible="{Binding ThumbnailImage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                  <TextBlock Text="No Preview"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Opacity="0.3"
                             IsVisible="{Binding ThumbnailImage, Converter={x:Static ObjectConverters.IsNull}}"/>
                </Grid>
              </Border>

              <!-- Metadata -->
              <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                <Grid ColumnDefinitions="Auto,*"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      Margin="0">

                  <TextBlock Grid.Row="0" Grid.Column="0"
                             Text="Model ID:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,6"/>
                  <TextBlock Grid.Row="0" Grid.Column="1"
                             Text="{Binding ModelIdDisplay}"
                             Foreground="White"
                             Margin="0,0,0,6"/>

                  <TextBlock Grid.Row="1" Grid.Column="0"
                             Text="Version ID:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,6"/>
                  <TextBlock Grid.Row="1" Grid.Column="1"
                             Text="{Binding VersionIdDisplay}"
                             Foreground="White"
                             Margin="0,0,0,6"/>

                  <TextBlock Grid.Row="2" Grid.Column="0"
                             Text="Base Model:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,6"/>
                  <TextBlock Grid.Row="2" Grid.Column="1"
                             Text="{Binding BaseModelDisplay}"
                             Foreground="White"
                             Margin="0,0,0,6"/>

                  <TextBlock Grid.Row="3" Grid.Column="0"
                             Text="File:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,6"/>
                  <TextBlock Grid.Row="3" Grid.Column="1"
                             Text="{Binding FileNameDisplay}"
                             Foreground="White"
                             TextWrapping="Wrap"
                             Margin="0,0,0,6"/>

                  <TextBlock Grid.Row="4" Grid.Column="0"
                             Text="Type:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,6"/>
                  <TextBlock Grid.Row="4" Grid.Column="1"
                             Text="{Binding ModelTypeDisplay}"
                             Foreground="White"
                             Margin="0,0,0,6"/>

                  <TextBlock Grid.Row="5" Grid.Column="0"
                             Text="Creator:"
                             Foreground="#FF66AA"
                             FontWeight="SemiBold"
                             Margin="0,0,12,0"/>
                  <TextBlock Grid.Row="5" Grid.Column="1"
                             Text="{Binding CreatorDisplay}"
                             Foreground="White"/>
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Trigger Words Section -->
          <Border Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasTriggerWords}">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Trigger Words"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="White"/>
                <Button Grid.Column="1"
                        Content="Copy"
                        Command="{Binding CopyTriggerWordsCommand}"
                        ToolTip.Tip="Copy trigger words"
                        Padding="6,2"
                        FontSize="11"
                        Background="Transparent"
                        Foreground="#66CCFF"/>
              </Grid>
              <Border Background="#252525"
                      CornerRadius="4"
                      Padding="10,8">
                <TextBlock Text="{Binding TriggerWordsDisplay}"
                           Foreground="#66CCFF"
                           TextWrapping="Wrap"
                           FontSize="13"/>
              </Border>
            </StackPanel>
          </Border>

          <!-- Tags Section -->
          <Border Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1"
                  IsVisible="{Binding HasTags}">
            <StackPanel Spacing="6">
              <TextBlock Text="Tags"
                         FontWeight="Bold"
                         FontSize="14"
                         Foreground="White"/>
              <ItemsControl ItemsSource="{Binding TagItems}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#333"
                            CornerRadius="4"
                            Padding="8,4"
                            Margin="0,0,4,4">
                      <TextBlock Text="{Binding}"
                                 Foreground="#AAAAAA"
                                 FontSize="12"/>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Description Section -->
          <Border Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
              <TextBlock Text="Description"
                         FontWeight="Bold"
                         FontSize="14"
                         Foreground="White"/>
              <Border Background="#252525"
                      CornerRadius="4"
                      Padding="12,10">
                <TextBlock Text="{Binding DescriptionText}"
                           Foreground="#CCCCCC"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="20"/>
              </Border>
            </StackPanel>
          </Border>

          <!-- Action Buttons -->
          <Border Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Right">
              <Button Content="Open on Civitai"
                      Command="{Binding OpenOnCivitaiCommand}"
                      Padding="10,6"
                      FontSize="12"/>
            </StackPanel>
          </Border>

          <!-- Loading Indicator -->
          <Border IsVisible="{Binding IsLoading}"
                  Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center">
              <ProgressBar IsIndeterminate="True" Width="100"/>
              <TextBlock Text="{Binding StatusMessage}"
                         Foreground="#888"
                         FontSize="12"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Status Message (when not loading) -->
          <Border IsVisible="{Binding !IsLoading}"
                  Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#888"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
          </Border>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Border>

</UserControl>
