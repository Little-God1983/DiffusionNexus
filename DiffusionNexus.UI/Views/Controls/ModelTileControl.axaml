<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="340"
             x:Class="DiffusionNexus.UI.Views.Controls.ModelTileControl"
             x:DataType="vm:ModelTileViewModel">

  <Design.DataContext>
    <vm:ModelTileViewModel/>
  </Design.DataContext>

  <Border Background="#2D2D2D"
          CornerRadius="8"
          BorderBrush="#3D3D3D"
          BorderThickness="1"
          ClipToBounds="True"
          Cursor="Hand">

    <Grid RowDefinitions="*,Auto">

      <!-- Thumbnail Area -->
      <Border Grid.Row="0"
              Height="260"
              Margin="0"
              Background="#1A1A1A"
              ClipToBounds="True">

        <Grid>
          <!-- Actual Image -->
          <Image Source="{Binding ThumbnailImage}"
                 Stretch="UniformToFill"
                 IsVisible="{Binding HasThumbnail}"/>

          <!-- Placeholder -->
          <Border IsVisible="{Binding ShowPlaceholder}"
                  Background="#252525">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <Border Background="#333" CornerRadius="8" Padding="12,8">
                <TextBlock Text="No Preview" FontSize="11" Opacity="0.4" HorizontalAlignment="Center"/>
              </Border>
            </StackPanel>
          </Border>

          <!-- Loading Indicator -->
          <Border IsVisible="{Binding IsLoading}"
                  Background="#80000000">
            <ProgressBar IsIndeterminate="True" Width="80" VerticalAlignment="Center"/>
          </Border>

          <!-- NSFW Badge -->
          <Border IsVisible="{Binding IsNsfw}"
                  Background="#E53935"
                  CornerRadius="4"
                  Padding="6,2"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="4">
            <TextBlock Text="NSFW" FontSize="9" FontWeight="Bold" Foreground="White"/>
          </Border>

          <!-- Grouped Badge -->
          <Border IsVisible="{Binding IsGrouped}"
                  Background="#0078D4"
                  CornerRadius="4"
                  Padding="6,2"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="4"
                  Opacity="0.9">
            <TextBlock Text="{Binding VersionCountDisplay}" 
                       FontSize="9" FontWeight="Bold" Foreground="White"/>
          </Border>
        </Grid>
      </Border>

      <!-- Version Selector Label Buttons (overlay on thumbnail top) -->
      <Border Grid.Row="0"
              VerticalAlignment="Top"
              Background="#CC000000"
              Padding="4,4,4,2"
              CornerRadius="8,8,0,0">
        <ItemsControl ItemsSource="{Binding VersionButtons}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:VersionButtonViewModel">
              <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            Command="{Binding SelectCommand}"
                            ToolTip.Tip="{Binding ToolTip}"
                            Margin="2"
                            Padding="8,4"
                            FontSize="11"
                            MinWidth="44"
                            CornerRadius="4">
                <ToggleButton.Styles>
                  <Style Selector="ToggleButton">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0"/>
                  </Style>
                  <Style Selector="ToggleButton:pointerover">
                    <Setter Property="Background" Value="#606060"/>
                  </Style>
                  <Style Selector="ToggleButton:checked">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </ToggleButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Icon}" IsVisible="{Binding HasIcon}"/>
                  <TextBlock Text="{Binding Label}"/>
                </StackPanel>
              </ToggleButton>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <!-- Model Info: Name + Filename (overlay on thumbnail bottom) -->
      <Border Grid.Row="0"
              VerticalAlignment="Bottom"
              Background="#CC000000"
              Padding="8,4">
        <StackPanel Spacing="1">
          <TextBlock Text="{Binding DisplayName}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="White"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding DisplayName}"/>
          <TextBlock Text="{Binding FileName}"
                     FontSize="11"
                     Foreground="#99FFFFFF"
                     TextTrimming="CharacterEllipsis"
                     ToolTip.Tip="{Binding FileName}"/>
        </StackPanel>
      </Border>

      <!-- Bottom Action Buttons -->
      <Border Grid.Row="1"
              Background="#252525"
              Padding="8,4"
              Margin="0"
              CornerRadius="0,0,8,8">
        
        <Grid ColumnDefinitions="*,*,*,*,*">

          <!-- Open on Civitai -->
          <Button Grid.Column="0"
                  Content="🌐"
                  Command="{Binding OpenOnCivitaiCommand}"
                  ToolTip.Tip="Open on Civitai"
                  HorizontalAlignment="Center"
                  Padding="6,4"
                  FontSize="10"/>

          <!-- Copy Trigger Words -->
          <Button Grid.Column="1"
                  Content="📋"
                  Command="{Binding CopyTriggerWordsCommand}"
                  ToolTip.Tip="Copy Trigger Words"
                  HorizontalAlignment="Center"
                  Padding="6,4"
                  FontSize="10"/>

          <!-- Copy Real Filename -->
          <Button Grid.Column="2"
                  Content="🧾"
                  Command="{Binding CopyFileNameCommand}"
                  ToolTip.Tip="Copy Filename to Clipboard (for ComfyUI search)"
                  HorizontalAlignment="Center"
                  Padding="6,4"
                  FontSize="10"/>

          <!-- Open Folder -->
          <Button Grid.Column="3"
                  Content="📁"
                  Command="{Binding OpenFolderCommand}"
                  ToolTip.Tip="Open Folder"
                  HorizontalAlignment="Center"
                  Padding="6,4"
                  FontSize="10"/>

          <!-- Delete -->
          <Button Grid.Column="4"
                  Content="❌"
                  FontWeight="Bold"
                  Foreground="#FF6B6B"
                  Command="{Binding DeleteCommand}"
                  ToolTip.Tip="Delete Model"
                  HorizontalAlignment="Center"
                  Padding="6,4"
                  FontSize="10"/>
          
        </Grid>
      </Border>

    </Grid>

  </Border>
</UserControl>
