<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="340"
             x:Class="DiffusionNexus.UI.Views.Controls.ModelTileControl"
             x:DataType="vm:ModelTileViewModel">

  <Design.DataContext>
    <vm:ModelTileViewModel/>
  </Design.DataContext>

  <Border Background="#2D2D2D"
          CornerRadius="8"
          BorderBrush="#3D3D3D"
          BorderThickness="1"
          ClipToBounds="True"
          Cursor="Hand"
          Classes="tile">
    <Border.Styles>
      <!-- The action buttons are laid out only while the tile is hovered. During scroll
           they are collapsed (IsVisible=False → not measured/arranged), which removes the
           bulk of the per-tile layout cost that made fast scrolling stutter; they reveal
           on pointer-over. -->
      <Style Selector="Border.tile Grid.tileActions">
        <Setter Property="IsVisible" Value="False"/>
      </Style>
      <Style Selector="Border.tile:pointerover Grid.tileActions">
        <Setter Property="IsVisible" Value="True"/>
      </Style>
    </Border.Styles>

    <Grid>

      <!-- Thumbnail Area (clickable to open details) -->
      <Button Grid.Row="0"
              Command="{Binding OpenDetailsCommand}"
              Background="Transparent"
              Padding="0"
              BorderThickness="0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              VerticalContentAlignment="Stretch"
              CornerRadius="0"
              Cursor="Hand">
        <Border Height="260"
                Margin="0"
                Background="#1A1A1A"
                ClipToBounds="True">

          <Grid>
            <!-- Actual Image -->
            <Image Source="{Binding ThumbnailImage}"
                   Stretch="UniformToFill"
                   IsVisible="{Binding HasThumbnail}"/>

            <!-- Placeholder -->
            <Border IsVisible="{Binding ShowPlaceholder}"
                    Background="#252525">
              <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#333" CornerRadius="8" Padding="12,8">
                  <TextBlock Text="No Preview" FontSize="11" Opacity="0.4" HorizontalAlignment="Center"/>
                </Border>
              </StackPanel>
            </Border>

            <!-- Loading Indicator -->
            <Border IsVisible="{Binding IsLoading}"
                    Background="#80000000">
              <ProgressBar IsIndeterminate="True" Width="80" VerticalAlignment="Center"/>
            </Border>

                </Grid>
              </Border>
            </Button>

            <!-- Version Selector / Base-Model Label Buttons (overlay on thumbnail top).
                 Always shown when there is at least one version button so the base-model
                 label (e.g. "SDXL") is visible even for single-version models.
                 Left-aligned so it doesn't span the full top edge and cover the
                 NSFW / extra-versions badges on the right. -->
            <Border Grid.Row="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#CC000000"
                    Padding="4,4,4,2"
                    CornerRadius="8,0,0,0">
        <ItemsControl ItemsSource="{Binding VersionButtons}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:VersionButtonViewModel">
              <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            Command="{Binding SelectCommand}"
                            ToolTip.Tip="{Binding ToolTip}"
                            Margin="2"
                            Padding="8,4"
                            FontSize="11"
                            MinWidth="44"
                            CornerRadius="4">
                <ToggleButton.Styles>
                  <Style Selector="ToggleButton">
                    <Setter Property="Background" Value="#505050"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0"/>
                  </Style>
                  <Style Selector="ToggleButton:pointerover">
                    <Setter Property="Background" Value="#606060"/>
                  </Style>
                  <Style Selector="ToggleButton:checked">
                    <Setter Property="Background" Value="#0078D4"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                  </Style>
                </ToggleButton.Styles>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="{Binding Icon}" IsVisible="{Binding HasIcon}"/>
                  <TextBlock Text="{Binding Label}"/>
                </StackPanel>
              </ToggleButton>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <!-- Model Info (name + filename, always visible) with the action buttons stacked
           directly below, revealed on hover. Kept as a single bottom-anchored overlay so
           revealing the actions never reflows the tile. -->
      <Border Grid.Row="0"
              VerticalAlignment="Bottom"
              Background="#CC000000"
              Padding="0">
        <StackPanel>
          <StackPanel Spacing="1" Margin="8,4">
            <TextBlock Text="{Binding DisplayName}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="White"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding DisplayName}"/>
            <TextBlock Text="{Binding FileName}"
                       FontSize="11"
                       Foreground="#99FFFFFF"
                       TextTrimming="CharacterEllipsis"
                       ToolTip.Tip="{Binding FileName}"/>
          </StackPanel>

          <!-- Action buttons: collapsed during scroll, shown on pointer-over (see .tileActions style). -->
          <Grid Classes="tileActions"
                ColumnDefinitions="*,*,*,*,*"
                Background="#252525"
                Margin="0"
                Height="34">
            <Button Grid.Column="0" Content="🌐" Command="{Binding OpenOnCivitaiCommand}" ToolTip.Tip="Open on Civitai" HorizontalAlignment="Center" Padding="6,4" FontSize="14"/>
            <Button Grid.Column="1" Content="📋" Command="{Binding CopyTriggerWordsCommand}" ToolTip.Tip="Copy Trigger Words" HorizontalAlignment="Center" Padding="6,4" FontSize="14"/>
            <Button Grid.Column="2" Content="🧾" Command="{Binding CopyFileNameCommand}" ToolTip.Tip="Copy Filename to Clipboard (for ComfyUI search)" HorizontalAlignment="Center" Padding="6,4" FontSize="14"/>
            <Button Grid.Column="3" Content="📁" Command="{Binding OpenFolderCommand}" ToolTip.Tip="Open Folder" HorizontalAlignment="Center" Padding="6,4" FontSize="14"/>
            <Button Grid.Column="4" Content="❌" FontWeight="Bold" Foreground="#FF6B6B" Command="{Binding DeleteCommand}" ToolTip.Tip="Delete Model" HorizontalAlignment="Center" Padding="6,4" FontSize="14"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Top-right badges stacked vertically (NSFW first, additional versions below).
           Declared after the version-selector overlay so they always render on top
           and are no longer occluded by the dark version-selector strip. -->
      <StackPanel Grid.Row="0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="4"
                  Spacing="4">
        <!-- NSFW Badge -->
        <Border IsVisible="{Binding IsNsfw}"
                Background="#E53935"
                CornerRadius="4"
                Padding="6,2"
                HorizontalAlignment="Right">
          <TextBlock Text="NSFW" FontSize="9" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- More Versions Available Badge (Civitai has versions the user does not own locally).
             Sized to match the base-model version selector ToggleButtons (FontSize 11,
             Padding 8,4, MinWidth 44) so the two overlays read as a consistent badge family. -->
        <Border IsVisible="{Binding HasAdditionalVersions}"
                Background="#7B1FA2"
                CornerRadius="4"
                Padding="8,4"
                MinWidth="44"
                HorizontalAlignment="Right"
                Opacity="0.9"
                ToolTip.Tip="{Binding AdditionalVersionsTooltip}">
          <TextBlock Text="{Binding AdditionalVersionsBadge}"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="White"
                     HorizontalAlignment="Center"/>
        </Border>
      </StackPanel>

    </Grid>

  </Border>
</UserControl>
