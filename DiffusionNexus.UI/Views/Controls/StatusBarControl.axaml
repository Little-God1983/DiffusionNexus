<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             xmlns:controls="using:DiffusionNexus.UI.Views.Controls"
             x:Class="DiffusionNexus.UI.Views.Controls.StatusBarControl"
             x:DataType="vm:StatusBarViewModel">

    <UserControl.Styles>
        <!-- Custom progress bar styling for status bar -->
        <Style Selector="ProgressBar.status-progress">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#00000033"/>
        </Style>
        <!-- Backup progress bar - more prominent -->
        <Style Selector="ProgressBar.backup-progress">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="Background" Value="#1E7E34"/>
        </Style>
        <!-- Spinning animation for backup indicator -->
        <Style Selector="TextBlock.spinning">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <RotateTransform/>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Compact pinned running instance card -->
        <Style Selector="Border.pinned-inst">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>
        <Style Selector="Button.pinned-stop">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pinned-restart">
            <Setter Property="Background" Value="#0088CC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pinned-webui">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#0088CC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto">

        <!-- Expandable Unified Console Panel (replaces old Activity Log) -->
        <Border Grid.Row="0"
                Height="250"
                IsVisible="{Binding IsLogPanelOpen}">
            <controls:UnifiedConsoleView DataContext="{Binding UnifiedConsole}"/>
        </Border>

        <!-- Pinned Running Instances (visible only when console is hidden and instances are running) -->
        <Panel Grid.Row="1" IsVisible="{Binding !IsLogPanelOpen}">
            <Border Background="#1B1B1B" Padding="4,3" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0"
                    IsVisible="{Binding UnifiedConsole.HasRunningInstances}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding UnifiedConsole.InstanceTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InstanceTabItem">
                                <Border Classes="pinned-inst" IsVisible="{Binding IsRunning}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Image Source="{Binding Logo}" Width="16" Height="16"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding Logo, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <Ellipse Width="7" Height="7" Fill="#4CAF50" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="100"/>
                                        <!-- Stop -->
                                        <Button Classes="pinned-stop"
                                                Command="{Binding $parent[UserControl].((vm:StatusBarViewModel)DataContext).UnifiedConsole.StopInstanceCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                <TextBlock Text="&#x25A0;" FontSize="8" VerticalAlignment="Center"/>
                                                <TextBlock Text="Stop" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Restart -->
                                        <Button Classes="pinned-restart"
                                                Command="{Binding $parent[UserControl].((vm:StatusBarViewModel)DataContext).UnifiedConsole.RestartInstanceCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                <TextBlock Text="&#x21BB;" FontSize="10" VerticalAlignment="Center"/>
                                                <TextBlock Text="Restart" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Web UI (when URL detected) -->
                                        <Button Classes="pinned-webui"
                                                IsVisible="{Binding DetectedWebUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                Command="{Binding $parent[UserControl].((vm:StatusBarViewModel)DataContext).UnifiedConsole.OpenInstanceWebUiCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                <TextBlock Text="&#x2197;" FontSize="10"/>
                                                <TextBlock Text="Web UI"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Panel>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{Binding StatusBackground}"
                Height="24">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                
                <!-- Status Message (hidden when backup or download in progress) -->
                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal" 
                            Spacing="8"
                            Margin="8,0"
                            IsVisible="{Binding !ShowBackupProgress}">
                    <StackPanel.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!ShowBackupProgress"/>
                            <Binding Path="!ShowDownloadProgress"/>
                        </MultiBinding>
                    </StackPanel.IsVisible>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{Binding StatusForeground}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Backup Progress Bar (shown when backup in progress, takes priority over download) -->
                <Grid Grid.Column="0"
                      Margin="8,0"
                      IsVisible="{Binding ShowBackupProgress}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Spinning hourglass animation -->
                    <TextBlock Grid.Column="0"
                               Text="⏳"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{Binding StatusForeground}"
                               Margin="0,0,8,0"
                               Classes="spinning"/>

                    <!-- Backup operation name / live step label (e.g. "Zipping dataset images — 142/500") -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding BackupOperationName, FallbackValue='Backup running...'}"
                               Foreground="{Binding StatusForeground}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               MaxWidth="380"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,12,0"/>

                    <!-- Progress bar that fills available space. Indeterminate for steps that can't
                         report a percentage (e.g. the database copy). -->
                    <ProgressBar Grid.Column="2"
                                 Value="{Binding BackupProgressPercent}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="{Binding BackupIsIndeterminate}"
                                 Classes="backup-progress"/>

                    <!-- Percentage text (hidden while the step is indeterminate) -->
                    <TextBlock Grid.Column="3"
                               Text="{Binding BackupProgressPercent, StringFormat='{}{0}%'}"
                               Foreground="{Binding StatusForeground}"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !BackupIsIndeterminate}"
                               Margin="8,0,0,0"/>
                </Grid>

                <!-- Download Progress Bar (shown when download in progress and no backup running).
                     Wrapped in a Button with a Flyout so users can click to see the full per-download
                     list — active + queued — instead of just the aggregate summary line. -->
                <Button Grid.Column="0"
                        Margin="8,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Cursor="Hand">
                    <Button.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="ShowDownloadProgress"/>
                            <Binding Path="!ShowBackupProgress"/>
                        </MultiBinding>
                    </Button.IsVisible>
                    <Button.Flyout>
                        <Flyout Placement="Top">
                            <Border Background="#252525"
                                    BorderBrush="#3D3D3D"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    MinWidth="360"
                                    MaxWidth="540">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Downloads"
                                               FontWeight="Bold" FontSize="13"
                                               Foreground="White"/>
                                    <ItemsControl ItemsSource="{Binding DownloadTasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DownloadTaskRowViewModel">
                                                <Grid Margin="0,4"
                                                      ColumnDefinitions="*,Auto,Auto"
                                                      RowDefinitions="Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding Name}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding StatusLabel}"
                                                               Foreground="{Binding StatusColor}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                    <!-- Cancel button. Only shown while the task is queued
                                                         or active; hidden once terminal so the flyout doesn't
                                                         offer to cancel something that's already finished. -->
                                                    <Button Grid.Row="0" Grid.Column="2"
                                                            Content="✖"
                                                            FontSize="12"
                                                            Padding="6,2"
                                                            Margin="6,0,0,0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="#BBBBBB"
                                                            Cursor="Hand"
                                                            ToolTip.Tip="Cancel this download"
                                                            Command="{Binding CancelCommand}"
                                                            IsVisible="{Binding CanCancel}"/>
                                                    <ProgressBar Grid.Row="1" Grid.ColumnSpan="3"
                                                                 Value="{Binding Percent}"
                                                                 Minimum="0" Maximum="100"
                                                                 Height="4" Margin="0,2,0,2"
                                                                 IsVisible="{Binding IsActive}"
                                                                 Foreground="#0088CC"/>
                                                    <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                                               Text="{Binding StatusMessage}"
                                                               FontSize="11" Foreground="#999999"
                                                               TextTrimming="CharacterEllipsis"
                                                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Download arrow icon -->
                        <TextBlock Grid.Column="0"
                                   Text="⬇"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding StatusForeground}"
                                   Margin="0,0,8,0"/>

                        <!-- Download operation name (single download → its name; multiple → "N Downloads in progress" via DownloadOperationName) -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding DownloadOperationName, FallbackValue='Downloading...'}"
                                   Foreground="{Binding StatusForeground}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <!-- Progress bar (aggregate average when >1 active) -->
                        <ProgressBar Grid.Column="2"
                                     Value="{Binding DownloadProgressPercent}"
                                     Minimum="0"
                                     Maximum="100"
                                     Height="8"
                                     VerticalAlignment="Center"
                                     Classes="backup-progress"/>

                        <!-- Percentage text -->
                        <TextBlock Grid.Column="3"
                                   Text="{Binding DownloadProgressPercent, StringFormat='{}{0}%'}"
                                   Foreground="{Binding StatusForeground}"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>

                        <!-- Chevron hinting that the flyout is expandable. Always shown
                             while the parent button is visible (i.e. a download is active). -->
                        <TextBlock Grid.Column="4"
                                   Text="▾"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding StatusForeground}"
                                   Margin="6,0,0,0"/>
                    </Grid>
                </Button>
                
                <!-- Active Operation Progress (when not backup) -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,0,16,0"
                            IsVisible="{Binding HasActiveOperation}">
                    <TextBlock Text="{Binding ActiveOperationName}"
                               Foreground="{Binding StatusForeground}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Opacity="0.9"/>
                    <ProgressBar Value="{Binding ActiveOperationProgress, TargetNullValue=0, FallbackValue=0}"
                                 Minimum="0"
                                 Maximum="100"
                                 Width="100"
                                 Height="6"
                                 VerticalAlignment="Center"
                                 Classes="status-progress"
                                 IsIndeterminate="{Binding ActiveOperationProgress, Converter={x:Static ObjectConverters.IsNull}}"/>
                    <TextBlock Text="{Binding ActiveOperationProgress, StringFormat='{}{0}%'}"
                               Foreground="{Binding StatusForeground}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ActiveOperationProgress, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </StackPanel>
                
                <!-- Warning/Error Counts -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,0,8,0"
                            IsVisible="{Binding HasWarningsOrErrors}">
                    <Button Padding="4,2"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowLogPanelCommand}"
                            IsVisible="{Binding WarningCount}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="?" FontSize="12" Foreground="#000000"/>
                            <TextBlock Text="{Binding WarningCount}" 
                                       FontSize="11" 
                                       Foreground="#000000"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="4,2"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Command="{Binding ShowLogPanelCommand}"
                            IsVisible="{Binding ErrorCount}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="?" FontSize="12" Foreground="#FFFFFF" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ErrorCount}" 
                                       FontSize="11" 
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Toggle Log Panel Button -->
                <Button Grid.Column="4"
                        Command="{Binding ToggleLogPanelCommand}"
                        Padding="12,0"
                        Background="#00000033"
                        BorderThickness="0"
                        Foreground="{Binding StatusForeground}"
                        FontSize="12"
                        FontWeight="SemiBold"
                        VerticalContentAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="Toggle Unified Console">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Panel>
                            <TextBlock Text="▼ Hide Console" IsVisible="{Binding IsLogPanelOpen}" FontSize="11"/>
                            <TextBlock Text="▲ Show Console" IsVisible="{Binding !IsLogPanelOpen}" FontSize="11"/>
                        </Panel>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
