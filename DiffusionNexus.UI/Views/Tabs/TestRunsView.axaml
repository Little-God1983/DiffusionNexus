<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vmTabs="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:models="using:DiffusionNexus.Domain.Models"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.Tabs.TestRunsView"
             x:DataType="vmTabs:TestRunsTabViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- TOP BAR -->
    <Border Grid.Row="0"
            Background="#1E1E1E"
            Padding="16,12"
            BorderBrush="#333"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="Analysis Run History"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Opacity="0.8"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1"
                Content="Refresh"
                Command="{Binding RefreshCommand}"
                Padding="14,8"
                Background="#444"
                Foreground="White"
                CornerRadius="4"
                VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- MAIN CONTENT: Left run list + Right detail -->
    <Grid Grid.Row="1" ColumnDefinitions="380,*">

      <!-- LEFT PANEL: Run List -->
      <Border Grid.Column="0"
              Background="#1A1A1A"
              BorderBrush="#333"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">

          <Border Grid.Row="0" Padding="12,10" Background="#222" BorderBrush="#333" BorderThickness="0,0,0,1">
            <TextBlock Text="Runs" FontSize="14" FontWeight="SemiBold" Opacity="0.9"/>
          </Border>

          <!-- Empty state -->
          <StackPanel Grid.Row="1"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding !HasRuns}">
            <TextBlock Text="No test runs yet"
                       FontSize="14" Opacity="0.5"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Run 'Analyze All' to create the first run"
                       FontSize="12" Opacity="0.3"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="280"/>
          </StackPanel>

          <!-- Loading indicator -->
          <StackPanel Grid.Row="1"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding IsLoading}">
            <ProgressBar IsIndeterminate="True" Width="120" Height="14"/>
            <TextBlock Text="Loading runs..." FontSize="12" Opacity="0.5" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Run list -->
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Runs}"
                   SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                   Background="Transparent"
                   IsVisible="{Binding HasRuns}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vmTabs:TestRunViewModel">
                <Border Padding="12,10" BorderBrush="#333" BorderThickness="0,0,0,1">
                  <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                    <!-- Timestamp + Version -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding VersionLabel}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="#81D4FA"/>
                      <TextBlock Text="{Binding Timestamp}"
                                 FontSize="12"
                                 Opacity="0.6"/>
                    </StackPanel>

                    <!-- Composite score badge -->
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding CompositeScore, StringFormat={}{0:F0}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{Binding CompositeScoreColor}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding CompositeScore, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                    <!-- File counts -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                      <TextBlock FontSize="11" Opacity="0.6">
                        <TextBlock.Text>
                          <MultiBinding StringFormat="{}{0} files  &#183;  {1} captions">
                            <Binding Path="ImageFiles"/>
                            <Binding Path="CaptionFiles"/>
                          </MultiBinding>
                        </TextBlock.Text>
                      </TextBlock>
                    </StackPanel>

                    <!-- Issue counts + duration -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                      <TextBlock Text="{Binding CriticalCount, StringFormat={}{0} critical}"
                                 FontSize="11" Foreground="#FF6B6B"
                                 IsVisible="{Binding CriticalCount}"/>
                      <TextBlock Text="{Binding WarningCount, StringFormat={}{0} warnings}"
                                 FontSize="11" Foreground="#FFA726"
                                 IsVisible="{Binding WarningCount}"/>
                      <TextBlock Text="{Binding InfoCount, StringFormat={}{0} info}"
                                 FontSize="11" Foreground="#4CAF50"
                                 IsVisible="{Binding InfoCount}"/>
                      <TextBlock Text="{Binding DurationText}"
                                 FontSize="11" Opacity="0.4"/>
                    </StackPanel>

                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- RIGHT PANEL: Run Detail -->
      <Border Grid.Column="1" Background="#1E1E1E">

        <!-- Empty state -->
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding !HasSelectedRun}">
          <TextBlock Text="Select a run to see details"
                     FontSize="14" Opacity="0.4"
                     HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>

      <!-- Detail scroll view (overlays empty state when visible) -->
      <ScrollViewer Grid.Column="1"
                    IsVisible="{Binding HasSelectedRun}"
                    Padding="20">
        <StackPanel Spacing="16"
                    DataContext="{Binding SelectedRun}"
                    x:CompileBindings="True"
                    x:DataType="vmTabs:TestRunViewModel">

          <!-- Header: Score + Timestamp -->
          <Grid ColumnDefinitions="Auto,*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
              <!-- Big score -->
              <StackPanel Orientation="Horizontal" Spacing="4"
                          IsVisible="{Binding CompositeScore, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="{Binding CompositeScore, StringFormat={}{0:F0}}"
                           FontSize="32" FontWeight="Bold"
                           Foreground="{Binding CompositeScoreColor}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="/100" FontSize="14" Opacity="0.4"
                           VerticalAlignment="Bottom" Margin="0,0,0,6"/>
              </StackPanel>
              <StackPanel Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding CompositeScoreLabel}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{Binding CompositeScoreColor}"/>
                <TextBlock Text="{Binding LoraTypeLabel, StringFormat='LoRA: {0}'}"
                           FontSize="11" Opacity="0.5"/>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Right">
              <TextBlock Text="{Binding Timestamp}" FontSize="13" Opacity="0.7"/>
              <TextBlock Text="{Binding DurationText, StringFormat='Duration: {0}'}"
                         FontSize="11" Opacity="0.4" HorizontalAlignment="Right"/>
            </StackPanel>
          </Grid>

          <!-- Category scores -->
          <Border Background="#222" CornerRadius="8" Padding="16" Margin="0,4,0,0">
            <StackPanel Spacing="10">
              <TextBlock Text="Category Scores" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
              <ItemsControl ItemsSource="{Binding CategoryScores}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vmTabs:CategoryScoreViewModel">
                    <Grid ColumnDefinitions="120,*,Auto,Auto" Margin="0,3">
                      <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                 FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                      <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                                   Value="{Binding Score}"
                                   Height="10" CornerRadius="5"
                                   VerticalAlignment="Center" Margin="8,0"/>
                      <TextBlock Grid.Column="2"
                                 Text="{Binding Score, StringFormat={}{0:F0}}"
                                 FontSize="12" FontWeight="SemiBold"
                                 Foreground="{Binding ScoreColor}"
                                 VerticalAlignment="Center" MinWidth="30"
                                 TextAlignment="Right"/>
                      <TextBlock Grid.Column="3"
                                 Text="{Binding Weight}"
                                 FontSize="10" Opacity="0.4"
                                 VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Summary stats -->
          <Border Background="#222" CornerRadius="8" Padding="16">
            <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto">
              <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="{Binding ImageFiles}" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Images" FontSize="11" Opacity="0.5" HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="{Binding CaptionFiles}" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Captions" FontSize="11" Opacity="0.5" HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="{Binding TotalIssues}" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Issues" FontSize="11" Opacity="0.5" HorizontalAlignment="Center"/>
              </StackPanel>
              <StackPanel Grid.Column="3" Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="{Binding DurationText}" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Duration" FontSize="11" Opacity="0.5" HorizontalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Issue breakdown -->
          <Border Background="#222" CornerRadius="8" Padding="16">
            <StackPanel Spacing="8">
              <TextBlock Text="Issues" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>
              <ItemsControl ItemsSource="{Binding Issues}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:RunIssueSnapshot">
                    <Border Padding="8,6" BorderBrush="#333" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Severity, Converter={x:Static vmTabs:SeverityIconConverter.Instance}}"
                                   FontSize="14"
                                   VerticalAlignment="Top"
                                   Margin="0,2,10,0"
                                   Classes.severity-critical="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.CriticalInstance}}"
                                   Classes.severity-warning="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.WarningInstance}}"
                                   Classes.severity-info="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.InfoInstance}}"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                          <TextBlock Text="{Binding CheckName}"
                                     FontSize="10" Opacity="0.5"
                                     TextTrimming="CharacterEllipsis"/>
                          <TextBlock Text="{Binding Message}"
                                     FontSize="12" TextWrapping="Wrap" MaxLines="2"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding AffectedFileCount, StringFormat='{}{0} files'}"
                                   FontSize="11" Opacity="0.4"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   IsVisible="{Binding AffectedFileCount}"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Delete button -->
          <Button Content="Delete Run"
                  Command="{Binding $parent[UserControl].((vmTabs:TestRunsTabViewModel)DataContext).DeleteRunCommand}"
                  CommandParameter="{Binding}"
                  Padding="12,6"
                  Background="#C62828"
                  Foreground="White"
                  FontWeight="SemiBold"
                  CornerRadius="4"
                  HorizontalAlignment="Left"/>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>

  <UserControl.Styles>
    <Style Selector="TextBlock.severity-critical">
      <Setter Property="Foreground" Value="#FF6B6B"/>
    </Style>
    <Style Selector="TextBlock.severity-warning">
      <Setter Property="Foreground" Value="#FFA726"/>
    </Style>
    <Style Selector="TextBlock.severity-info">
      <Setter Property="Foreground" Value="#4CAF50"/>
    </Style>
  </UserControl.Styles>

</UserControl>
