<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vmTabs="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:views="using:DiffusionNexus.UI.Views.Tabs"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.Tabs.ImageAnalysisView"
             x:DataType="vmTabs:ImageAnalysisTabViewModel">

  <UserControl.Styles>
    <Style Selector="Button.dashboard-card">
      <Setter Property="Background" Value="#222"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,12"/>
      <Setter Property="MinWidth" Value="220"/>
      <Setter Property="MinHeight" Value="90"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="BorderBrush" Value="#333"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.dashboard-card:pointerover">
      <Setter Property="Background" Value="#2A2A2A"/>
      <Setter Property="BorderBrush" Value="#555"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Background="#1A1A1A"
            Padding="16,12"
            BorderBrush="#333"
            BorderThickness="0,0,0,1">
      <StackPanel Spacing="8">
        <TextBlock Text="Image Analysis"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Opacity="0.7"
                   Margin="0,0,0,4"/>

        <ItemsControl ItemsSource="{Binding Cards}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vmTabs:AnalysisSectionCardViewModel">
              <Button Classes="dashboard-card"
                      Margin="0,0,12,8"
                      Command="{Binding $parent[UserControl].((vmTabs:ImageAnalysisTabViewModel)DataContext).SelectCardCommand}"
                      CommandParameter="{Binding}"
                      Tag="{Binding IsSelected}">
                <Grid RowDefinitions="Auto,Auto,Auto">
                  <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Icon}" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                  </StackPanel>

                  <TextBlock Grid.Row="1"
                             Text="{Binding Description}"
                             FontSize="11"
                             Opacity="0.5"
                             Margin="0,4,0,0"/>

                  <TextBlock Grid.Row="2"
                             Text="{Binding Summary}"
                             FontSize="12"
                             Opacity="0.8"
                             Margin="0,6,0,0"
                             FontWeight="SemiBold"/>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Panel Grid.Row="1">

      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="8"
                  IsVisible="{Binding !HasSelectedCard}">
        <TextBlock Text="Select an analysis section above"
                   FontSize="14" Opacity="0.4"
                   HorizontalAlignment="Center"/>
      </StackPanel>

      <Panel IsVisible="{Binding IsBucketAnalysisSelected}">
        <views:BucketAnalysisView DataContext="{Binding BucketAnalysisTab}"/>
      </Panel>

      <Panel IsVisible="{Binding IsImageQualitySelected}">
        <views:ImageQualityView DataContext="{Binding ImageQualityTab}"/>
      </Panel>

    </Panel>

  </Grid>
</UserControl>