<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vmTabs="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:models="using:DiffusionNexus.Domain.Models"
             xmlns:converters="using:DiffusionNexus.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="DiffusionNexus.UI.Views.Tabs.ColorDistributionView"
             x:DataType="vmTabs:ColorDistributionTabViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.severity-critical">
      <Setter Property="Foreground" Value="#FF6B6B"/>
    </Style>
    <Style Selector="TextBlock.severity-warning">
      <Setter Property="Foreground" Value="#FFA726"/>
    </Style>
    <Style Selector="TextBlock.severity-info">
      <Setter Property="Foreground" Value="#4CAF50"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- TOP BAR -->
    <Border Grid.Row="0"
            Background="#1E1E1E"
            Padding="16,12"
            BorderBrush="#333"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Grid.Column="0"
                   Text="Color Distribution Analysis"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Opacity="0.8"
                   VerticalAlignment="Center"/>

        <Button Grid.Column="1"
                Content="Analyze"
                Command="{Binding AnalyzeCommand}"
                Padding="14,8"
                Margin="0,0,8,0"
                Background="#4CAF50"
                Foreground="White"
                FontWeight="SemiBold"
                CornerRadius="4"/>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    IsVisible="{Binding IsAnalyzing}">
          <TextBlock Text="Analyzing..." FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- MAIN CONTENT (Left + Right) -->
    <Grid Grid.Row="1" ColumnDefinitions="350,*">

      <!-- LEFT PANEL: Issues -->
      <Border Grid.Column="0"
              Background="#1A1A1A"
              BorderBrush="#333"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">

          <!-- Summary -->
          <Border Grid.Row="0"
                  Background="#222"
                  Padding="12,8"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding SummaryText}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Opacity="0.9"/>
            </StackPanel>
          </Border>

          <!-- Issue List -->
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Issues}"
                   SelectedItem="{Binding SelectedIssue}"
                   Background="Transparent"
                   Padding="4">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:Issue">
                <Border Padding="8,6" CornerRadius="4" Margin="0,2">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Message}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Details}"
                               FontSize="11"
                               Opacity="0.5"
                               TextWrapping="Wrap"
                               MaxLines="2"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- RIGHT PANEL: Affected Images -->
      <ScrollViewer Grid.Column="1"
                    Padding="16">
        <Panel>

          <!-- No results yet -->
          <StackPanel IsVisible="{Binding !HasResults}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <TextBlock Text="Click Analyze to check color distribution"
                       FontSize="14"
                       Opacity="0.4"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Affected images when issue is selected -->
          <ItemsControl ItemsSource="{Binding AffectedImages}"
                        IsVisible="{Binding HasSelectedIssue}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vmTabs:ColorDistributionItemViewModel">
                <Border Background="#222"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,8">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding SeverityIcon}"
                               FontSize="16"
                               Foreground="{Binding ScoreColor}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding FileName}"
                                 FontSize="13"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Detail}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Score, StringFormat={}{0:F0}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{Binding ScoreColor}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- All images when no issue is selected -->
          <ItemsControl ItemsSource="{Binding AllImages}"
                        IsVisible="{Binding ShowAllImages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vmTabs:ColorDistributionItemViewModel">
                <Border Background="#222"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,8">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="{Binding SeverityIcon}"
                               FontSize="16"
                               Foreground="{Binding ScoreColor}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding FileName}"
                                 FontSize="13"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding Detail}"
                                 FontSize="11"
                                 Opacity="0.6"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Score, StringFormat={}{0:F0}}"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{Binding ScoreColor}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </Panel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
