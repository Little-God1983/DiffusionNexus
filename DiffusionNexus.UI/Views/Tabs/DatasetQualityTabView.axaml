<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vmTabs="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:models="using:DiffusionNexus.Domain.Models"
             xmlns:enums="using:DiffusionNexus.Domain.Enums"
             xmlns:controls="using:DiffusionNexus.UI.Views.Controls"
             xmlns:converters="using:DiffusionNexus.UI.Converters"
             xmlns:views="using:DiffusionNexus.UI.Views.Tabs"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.Tabs.DatasetQualityTabView"
             x:DataType="vmTabs:DatasetQualityTabViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.severity-critical">
      <Setter Property="Foreground" Value="#FF6B6B"/>
    </Style>
    <Style Selector="TextBlock.severity-warning">
      <Setter Property="Foreground" Value="#FFA726"/>
    </Style>
    <Style Selector="TextBlock.severity-info">
      <Setter Property="Foreground" Value="#4CAF50"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- TOP BAR -->
    <Border Grid.Row="0"
            Background="#1E1E1E"
            Padding="16,12"
            BorderBrush="#333"
            BorderThickness="0,0,0,1">
      <TextBlock Text="{Binding DatasetLabel}"
                 FontSize="14"
                 FontWeight="SemiBold"
                 Opacity="0.8"
                 VerticalAlignment="Center"/>
    </Border>

    <!-- TABBED CONTENT -->
    <TabControl Grid.Row="1" Padding="0">

      <!-- ═══════════ TAB 1: Image Analysis ═══════════ -->
      <TabItem Header="Image Analysis">
        <views:ImageAnalysisView DataContext="{Binding ImageAnalysisTab}"/>
      </TabItem>

      <!-- ═══════════ TAB 2: Caption Quality ═══════════ -->
      <TabItem Header="Caption Quality">
        <Grid RowDefinitions="Auto,*,Auto">

          <!-- Caption Quality top bar -->
          <Border Grid.Row="0"
                  Background="#1E1E1E"
                  Padding="16,12"
                  BorderBrush="#333"
                  BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">

              <!-- Spacer -->
              <Border Grid.Column="0"/>

              <!-- LoRA Type Dropdown -->
              <ComboBox Grid.Column="1"
                        ItemsSource="{Binding AvailableLoraTypes}"
                        SelectedItem="{Binding SelectedLoraType, Mode=TwoWay}"
                        MinWidth="120"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"/>

              <!-- Analyze Button -->
              <Button Grid.Column="2"
                      Content="Analyze"
                      Command="{Binding AnalyzeCommand}"
                      Padding="14,8"
                      Margin="0,0,8,0"
                      Background="#4CAF50"
                      Foreground="White"
                      FontWeight="SemiBold"
                      CornerRadius="4"/>

              <!-- Backup Button -->
              <Button Grid.Column="3"
                      Content="Backup"
                      Command="{Binding BackupCaptionsCommand}"
                      Padding="14,8"
                      Background="#444"
                      CornerRadius="4"/>

              <!-- Spinner -->
              <StackPanel Grid.Column="4"
                          Orientation="Horizontal"
                          Spacing="8"
                          VerticalAlignment="Center"
                          Margin="12,0,0,0"
                          IsVisible="{Binding IsAnalyzing}">
                <TextBlock Text="Analyzing..." FontSize="13" Opacity="0.7" VerticalAlignment="Center"/>
              </StackPanel>
            </Grid>
          </Border>

    <!-- MAIN CONTENT (Left + Right) -->
          <Grid Grid.Row="1" ColumnDefinitions="350,*">

      <!-- LEFT PANEL: Issue List -->
      <Border Grid.Column="0"
              Background="#1A1A1A"
              BorderBrush="#333"
              BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*">

          <Border Grid.Row="0" Padding="12,10" Background="#222" BorderBrush="#333" BorderThickness="0,0,0,1">
            <TextBlock Text="Issues" FontSize="14" FontWeight="SemiBold" Opacity="0.9"/>
          </Border>

          <!-- Empty state -->
          <StackPanel Grid.Row="1"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding !HasResults}">
            <TextBlock Text="No analysis results yet"
                       FontSize="14" Opacity="0.5"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Click Analyze to check this dataset"
                       FontSize="12" Opacity="0.3"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="280"/>
          </StackPanel>

          <!-- Issue list -->
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Issues}"
                   SelectedItem="{Binding SelectedIssue, Mode=TwoWay}"
                   Background="Transparent"
                   IsVisible="{Binding HasResults}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:Issue">
                <Border Padding="10,8" BorderBrush="#333" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Severity, Converter={x:Static vmTabs:SeverityIconConverter.Instance}}"
                               FontSize="16"
                               VerticalAlignment="Top"
                               Margin="0,2,10,0"
                               Classes.severity-critical="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.CriticalInstance}}"
                               Classes.severity-warning="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.WarningInstance}}"
                               Classes.severity-info="{Binding Severity, Converter={x:Static vmTabs:SeverityMatchConverter.InfoInstance}}"/>
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding CheckName}"
                                 FontSize="11"
                                 Opacity="0.5"
                                 TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding Message}"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 MaxLines="3"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <!-- RIGHT PANEL: Issue Detail -->
      <Border Grid.Column="1" Background="#1E1E1E">
        <Grid RowDefinitions="*">

          <StackPanel VerticalAlignment="Center"
                      HorizontalAlignment="Center"
                      Spacing="8"
                      IsVisible="{Binding !HasSelectedIssue}">
            <TextBlock Text="Select an issue to see details"
                       FontSize="14" Opacity="0.4"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <ScrollViewer IsVisible="{Binding HasSelectedIssue}" Padding="20">
            <StackPanel Spacing="16"
                        DataContext="{Binding}"
                        x:CompileBindings="True"
                        x:DataType="vmTabs:DatasetQualityTabViewModel">

              <!-- Severity badge + Check Name -->
              <StackPanel Orientation="Horizontal" Spacing="10">
                <Border Padding="8,4" CornerRadius="4"
                        Background="{Binding SelectedIssue.Severity, Converter={x:Static vmTabs:SeverityBackgroundConverter.Instance}}">
                  <TextBlock Text="{Binding SelectedIssue.Severity}"
                             FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                </Border>
                <TextBlock Text="{Binding SelectedIssue.CheckName}"
                           FontSize="14" Opacity="0.7"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <TextBlock Text="{Binding SelectedIssue.Message}"
                         FontSize="16" FontWeight="SemiBold"
                         TextWrapping="Wrap"/>

              <TextBlock Text="{Binding SelectedIssue.Details}"
                         FontSize="13" Opacity="0.8"
                         TextWrapping="Wrap"
                         IsVisible="{Binding SelectedIssue.Details, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Fix Suggestions with Inline File Editing -->
              <Border IsVisible="{Binding HasFixSuggestions}"
                      Background="#222" CornerRadius="8" Padding="12" Margin="0,4,0,0">
                <StackPanel Spacing="8">
                  <TextBlock Text="Fix Suggestions" FontSize="13" FontWeight="SemiBold" Opacity="0.8"/>

                  <ItemsControl ItemsSource="{Binding MergedFixSuggestions}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vmTabs:FixSuggestionViewModel">
                        <Border Background="#2A2A2A" CornerRadius="6" Padding="12" Margin="0,4">
                          <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                              <TextBlock Grid.Column="0"
                                         Text="{Binding Description}"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         TextWrapping="Wrap"
                                         VerticalAlignment="Center"/>
                              <Button Grid.Column="1"
                                      Content="Expand All"
                                      Command="{Binding ExpandAllCommand}"
                                      Padding="8,3"
                                      FontSize="11"
                                      Background="#333"
                                      Foreground="#AAA"
                                      CornerRadius="3"
                                      Margin="0,0,4,0"
                                      VerticalAlignment="Center"/>
                              <Button Grid.Column="2"
                                      Content="Collapse All"
                                      Command="{Binding CollapseAllCommand}"
                                      Padding="8,3"
                                      FontSize="11"
                                      Background="#333"
                                      Foreground="#AAA"
                                      CornerRadius="3"
                                      VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Per-file edits with diff + inline editor -->
                            <ItemsControl ItemsSource="{Binding Edits}">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vmTabs:FixEditWithEditor">
                                  <Border Background="#1A1A1A" CornerRadius="4" Padding="0" Margin="0,2">
                                    <StackPanel>
                                      <!-- Clickable file header -->
                                      <Button Command="{Binding Editor.ToggleExpandCommand}"
                                              Padding="12,8"
                                              MinHeight="36"
                                              Background="Transparent"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              CornerRadius="4"
                                              Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                          <TextBlock Grid.Column="0"
                                                     Text="{Binding Editor.IsExpanded, Converter={x:Static vmTabs:ExpandCollapseIconConverter.Instance}}"
                                                     FontSize="10"
                                                     Opacity="0.5"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                                          <TextBlock Grid.Column="1"
                                                     Text="{Binding Editor.FileName}"
                                                     FontSize="12"
                                                     FontFamily="Consolas,Courier New,monospace"
                                                     Opacity="0.7"
                                                     TextTrimming="CharacterEllipsis"
                                                     VerticalAlignment="Center"
                                                     ToolTip.Tip="{Binding Editor.FilePath}"/>
                                          <!-- Unsaved changes indicator -->
                                          <TextBlock Grid.Column="2"
                                                     Text="●"
                                                     FontSize="10"
                                                     Foreground="#FFA726"
                                                     VerticalAlignment="Center"
                                                     Margin="8,0,0,0"
                                                     IsVisible="{Binding Editor.HasUnsavedChanges}"/>
                                        </Grid>
                                      </Button>

                                      <!-- Diff preview -->
                                      <Border Padding="12,4">
                                        <StackPanel Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                          <TextBlock Text="&#8722;"
                                                     FontSize="12"
                                                     Foreground="#FF6B6B"
                                                     FontFamily="Consolas,Courier New,monospace"/>
                                          <TextBlock Text="{Binding DiffOriginalSnippet}"
                                                     FontSize="12"
                                                     Foreground="#FF6B6B"
                                                     FontFamily="Consolas,Courier New,monospace"
                                                     TextTrimming="CharacterEllipsis"
                                                     MaxWidth="500"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                          <TextBlock Text="+"
                                                     FontSize="12"
                                                     Foreground="#4CAF50"
                                                     FontFamily="Consolas,Courier New,monospace"/>
                                          <TextBlock Text="{Binding DiffNewSnippet}"
                                                     FontSize="12"
                                                     Foreground="#4CAF50"
                                                     FontFamily="Consolas,Courier New,monospace"
                                                     TextTrimming="CharacterEllipsis"
                                                     MaxWidth="500"/>
                                        </StackPanel>
                                        </StackPanel>
                                      </Border>

                                      <!-- Expandable editor with image preview -->
                                      <Border IsVisible="{Binding Editor.IsExpanded}"
                                              Padding="10,4,10,10"
                                              BorderBrush="#333"
                                              BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="Auto,*">
                                          <!-- Image preview -->
                                          <Border Grid.Column="0"
                                                  IsVisible="{Binding Editor.ImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                  CornerRadius="4"
                                                  ClipToBounds="True"
                                                  Margin="0,4,10,4"
                                                  MaxWidth="240"
                                                  MaxHeight="200"
                                                  VerticalAlignment="Top">
                                            <Image Source="{Binding Editor.ImagePath, Converter={x:Static converters:PathToBitmapConverter.Instance}}"
                                                   Stretch="Uniform"/>
                                          </Border>
                                          <!-- Caption editor -->
                                          <controls:CaptionEditorControl
                                              Grid.Column="1"
                                              Text="{Binding Editor.CaptionText, Mode=TwoWay}"
                                              HasUnsavedChanges="{Binding Editor.HasUnsavedChanges}"
                                              SaveCommand="{Binding Editor.SaveCommand}"
                                              ResetCommand="{Binding Editor.ResetCommand}"
                                              UndoCommand="{Binding Editor.UndoCommand}"
                                              RedoCommand="{Binding Editor.RedoCommand}"
                                              TextMinHeight="60"
                                              TextMaxHeight="160"
                                              TextFontSize="12"
                                              Watermark="Edit caption..."/>
                                        </Grid>
                                      </Border>
                                    </StackPanel>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="Apply Fix"
                                    Command="{Binding $parent[UserControl].((vmTabs:DatasetQualityTabViewModel)DataContext).ApplyFixCommand}"
                                    CommandParameter="{Binding Suggestion}"
                                    Padding="12,6"
                                    Background="#4CAF50"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <!-- Fallback: Affected Files only (no fix suggestions available) -->
              <Border IsVisible="{Binding HasAffectedFilesOnly}"
                      Background="#222" CornerRadius="8" Padding="12" Margin="0,4,0,0">
                <StackPanel Spacing="8">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Affected Files" FontSize="13" FontWeight="SemiBold" Opacity="0.8"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Expand All"
                            Command="{Binding ExpandAllFilesCommand}"
                            Padding="8,3"
                            FontSize="11"
                            Background="#333"
                            Foreground="#AAA"
                            CornerRadius="3"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="Collapse All"
                            Command="{Binding CollapseAllFilesCommand}"
                            Padding="8,3"
                            FontSize="11"
                            Background="#333"
                            Foreground="#AAA"
                            CornerRadius="3"
                            VerticalAlignment="Center"/>
                  </Grid>
                  <ItemsControl ItemsSource="{Binding EditableAffectedFiles}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vmTabs:EditableAffectedFile">
                        <Border Background="#1A1A1A" CornerRadius="4" Padding="0" Margin="0,2">
                          <StackPanel>
                            <!-- Clickable file header -->
                            <Button Command="{Binding ToggleExpandCommand}"
                                    Padding="12,10"
                                    MinHeight="40"
                                    Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    CornerRadius="4"
                                    Cursor="Hand">
                              <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding IsExpanded, Converter={x:Static vmTabs:ExpandCollapseIconConverter.Instance}}"
                                           FontSize="10"
                                           Opacity="0.5"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding FileName}"
                                           FontSize="12"
                                           FontFamily="Consolas,Courier New,monospace"
                                           Opacity="0.7"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="{Binding FilePath}"/>
                                <!-- Word count badge -->
                                <Border Grid.Column="2"
                                        IsVisible="{Binding HasRecommendedRange}"
                                        Padding="6,2"
                                        CornerRadius="3"
                                        Background="#2A2A2A"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"
                                        ToolTip.Tip="{Binding RecommendedRangeDisplay, StringFormat='Recommended: {0} words'}">
                                  <TextBlock FontSize="11"
                                             FontFamily="Consolas,Courier New,monospace"
                                             Opacity="0.7"
                                             VerticalAlignment="Center">
                                    <TextBlock.Text>
                                      <MultiBinding StringFormat="{}{0}w">
                                        <Binding Path="WordCount"/>
                                      </MultiBinding>
                                    </TextBlock.Text>
                                  </TextBlock>
                                </Border>
                                <!-- Direction arrow -->
                                <Panel Grid.Column="3"
                                       IsVisible="{Binding HasRecommendedRange}"
                                       Margin="6,0,0,0">
                                  <TextBlock Text="✓"
                                             FontSize="13"
                                             Foreground="#4CAF50"
                                             FontWeight="Bold"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding IsWithinRecommendedRange}"
                                             ToolTip.Tip="Word count is within the recommended range"/>
                                  <TextBlock Text="{Binding LengthDirectionIndicator}"
                                             FontSize="13"
                                             FontWeight="Bold"
                                             Foreground="#FFA726"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding !IsWithinRecommendedRange}"
                                             ToolTip.Tip="{Binding RecommendedRangeDisplay, StringFormat='Target: {0} words'}"/>
                                </Panel>
                                <!-- Unsaved changes indicator -->
                                <TextBlock Grid.Column="4"
                                           Text="●"
                                           FontSize="10"
                                           Foreground="#FFA726"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"
                                           IsVisible="{Binding HasUnsavedChanges}"/>
                              </Grid>
                            </Button>

                            <!-- Expandable editor with image preview -->
                            <Border IsVisible="{Binding IsExpanded}"
                                    Padding="10,4,10,10"
                                    BorderBrush="#333"
                                    BorderThickness="0,1,0,0">
                              <Grid ColumnDefinitions="Auto,*">
                                <!-- Image preview -->
                                <Border Grid.Column="0"
                                        IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        CornerRadius="4"
                                        ClipToBounds="True"
                                        Margin="0,4,10,4"
                                        MaxWidth="240"
                                        MaxHeight="200"
                                        VerticalAlignment="Top">
                                  <Image Source="{Binding ImagePath, Converter={x:Static converters:PathToBitmapConverter.Instance}}"
                                         Stretch="Uniform"/>
                                </Border>
                                <!-- Caption editor -->
                                <controls:CaptionEditorControl
                                    Grid.Column="1"
                                    Text="{Binding CaptionText, Mode=TwoWay}"
                                    HasUnsavedChanges="{Binding HasUnsavedChanges}"
                                    SaveCommand="{Binding SaveCommand}"
                                    ResetCommand="{Binding ResetCommand}"
                                    UndoCommand="{Binding UndoCommand}"
                                    RedoCommand="{Binding RedoCommand}"
                                    TextMinHeight="60"
                                    TextMaxHeight="160"
                                    TextFontSize="12"
                                    Watermark="Edit caption..."/>
                              </Grid>
                            </Border>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- BOTTOM STATUS BAR -->
    <Border Grid.Row="2"
            Background="#1A1A1A"
            Padding="16,8"
            BorderBrush="#333"
            BorderThickness="0,1,0,0"
            IsVisible="{Binding HasResults}">
      <TextBlock Text="{Binding SummaryText}"
                 FontSize="13"
                 Opacity="0.7"
                 VerticalAlignment="Center"/>
    </Border>

        </Grid>
      </TabItem>

    </TabControl>

  </Grid>
</UserControl>
