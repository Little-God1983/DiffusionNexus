<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:controls="using:DiffusionNexus.UI.Views.Controls"
             xmlns:converters="using:DiffusionNexus.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.Tabs.BatchUpscaleTabView"
             x:DataType="vm:BatchUpscaleTabViewModel">

  <Grid ColumnDefinitions="Auto,*">

    <!-- Left Settings Panel -->
    <ScrollViewer Grid.Column="0" Padding="16" Width="480">
      <StackPanel Spacing="16">

        <!-- Input Source -->
        <Border Background="#333333" CornerRadius="8" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Input Source" FontWeight="SemiBold" FontSize="14"/>

            <ToggleSwitch IsChecked="{Binding IsSingleImageMode}"
                          OnContent="Single Image"
                          OffContent="Dataset"
                          HorizontalAlignment="Left"/>

            <!-- Dataset Input -->
            <StackPanel IsVisible="{Binding !IsSingleImageMode}">
              <TextBlock Text="Select Dataset" Margin="0,0,0,4"/>
              <Grid ColumnDefinitions="*,Auto">
                <controls:DatasetVersionSelectorControl Grid.Column="0"
                    Datasets="{Binding AvailableDatasets}"
                    SelectedDataset="{Binding SelectedDataset, Mode=TwoWay}"
                    VersionItems="{Binding AvailableDatasetVersions}"
                    SelectedVersion="{Binding SelectedDatasetVersion, Mode=TwoWay}"
                    IsDatasetSearchable="False"
                    DatasetPlaceholderText="Choose a dataset..."/>
                <Button Grid.Column="1"
                        Content="&#x21BB;"
                        Command="{Binding RefreshDatasetsCommand}"
                        Margin="4,0,0,0"
                        ToolTip.Tip="Refresh dataset list"
                        Padding="8,6"/>
              </Grid>
              <TextBlock Text="{Binding DatasetImageCount, StringFormat='{}{0} images'}"
                         IsVisible="{Binding HasDatasetStats}"
                         Opacity="0.6" FontSize="12"/>
              <TextBlock Text="No images in selected version – select a different one."
                         IsVisible="{Binding IsSelectedVersionEmpty}"
                         Foreground="#FF5722" FontSize="12"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Single Image Input -->
            <StackPanel IsVisible="{Binding IsSingleImageMode}" Spacing="8">
              <!-- Drop zone (no image loaded) -->
              <Border x:Name="SingleImageDropZone"
                      Background="#1A1A1A" BorderBrush="#444" BorderThickness="2"
                      CornerRadius="8" Padding="16" MinHeight="100"
                      DragDrop.AllowDrop="True"
                      IsVisible="{Binding !HasSingleImage}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                  <TextBlock Text="No image loaded" FontSize="14" FontWeight="SemiBold"
                             HorizontalAlignment="Center" Opacity="0.6"/>
                  <TextBlock Text="Drag and drop an image here"
                             FontSize="12" Opacity="0.4" HorizontalAlignment="Center"/>
                  <Button Content="+ Open Image"
                          Command="{Binding SelectSingleImageCommand}"
                          HorizontalAlignment="Center"
                          Background="#4CAF50" Foreground="White"
                          Padding="12,6" Margin="0,4,0,0"/>
                </StackPanel>
              </Border>

              <!-- Loaded image info -->
              <Border Background="#1A1A1A" CornerRadius="8" Padding="12"
                      IsVisible="{Binding HasSingleImage}"
                      DragDrop.AllowDrop="True"
                      x:Name="SingleImageLoadedZone">
                <Grid ColumnDefinitions="Auto,8,*,Auto,Auto">
                  <TextBlock Grid.Column="0" Text="&#x1F5BC;" FontSize="20" VerticalAlignment="Center" Opacity="0.5"/>
                  <TextBlock Grid.Column="2" Text="{Binding SingleImageName}"
                             FontSize="13" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                  <Button Grid.Column="3" Content="..."
                          Command="{Binding SelectSingleImageCommand}"
                          Padding="8,4" Margin="4,0,0,0"
                          ToolTip.Tip="Choose a different image"/>
                  <Button Grid.Column="4" Content="X"
                          Command="{Binding ClearSingleImageCommand}"
                          Padding="8,4" Margin="4,0,0,0"
                          Foreground="#FF6B6B" FontWeight="Bold"
                          ToolTip.Tip="Remove image"/>
                </Grid>
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Upscale Settings -->
        <Border Background="#333333" CornerRadius="8" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Upscale Settings" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding DenoisingStrength, StringFormat='Denoising Strength (Change): {0:F2}'}"
                       Opacity="0.8"/>
            <Slider Minimum="0" Maximum="1"
                    Value="{Binding DenoisingStrength}"
                    TickFrequency="0.05" IsSnapToTickEnabled="True"/>
            <Grid ColumnDefinitions="*,*">
              <TextBlock Grid.Column="0" Text="Preserve Detail" Opacity="0.5" FontSize="10"
                         HorizontalAlignment="Left"/>
              <TextBlock Grid.Column="1" Text="More Creative" Opacity="0.5" FontSize="10"
                         HorizontalAlignment="Right"/>
            </Grid>

            <TextBlock Text="{Binding UpscaleFactor, StringFormat='Upscale Factor: {0:F1}x'}"
                       Opacity="0.8" Margin="0,8,0,0"/>
            <Slider Minimum="1.1" Maximum="4.0"
                    Value="{Binding UpscaleFactor}"
                    TickFrequency="0.1" IsSnapToTickEnabled="True"/>
            <Grid ColumnDefinitions="*,*">
              <TextBlock Grid.Column="0" Text="1.1x" Opacity="0.5" FontSize="10"
                         HorizontalAlignment="Left"/>
              <TextBlock Grid.Column="1" Text="4.0x" Opacity="0.5" FontSize="10"
                         HorizontalAlignment="Right"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Prompt Settings -->
        <Border Background="#333333" CornerRadius="8" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Prompt Mode" FontWeight="SemiBold" FontSize="14"/>
            <ComboBox ItemsSource="{Binding AvailablePromptModes}"
                      SelectedItem="{Binding PromptMode}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={x:Static converters:UpscaleEnumDisplayConverter.Instance}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding PromptModeDescription}"
                       TextWrapping="Wrap"
                       Opacity="0.5" FontSize="11" Margin="0,2,0,0"/>

            <!-- Manual prompt fields (visible only in ManualPrompt mode) -->
            <StackPanel Spacing="6" IsVisible="{Binding IsManualPromptMode}">
              <TextBlock Text="Positive Prompt" Margin="0,0,0,4"/>
              <TextBox Text="{Binding PositivePrompt}"
                       Watermark="Describe the desired image quality..."
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="60"
                       MaxHeight="120"/>
            </StackPanel>

            <TextBlock Text="Negative Prompt" Margin="0,0,0,4"/>
            <TextBox Text="{Binding NegativePrompt}"
                     Watermark="Things to avoid..."
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="40"
                     MaxHeight="80"/>
          </StackPanel>
        </Border>

        <!-- Save Settings (dataset mode only) -->
        <Border Background="#333333" CornerRadius="8" Padding="16"
                IsVisible="{Binding IsDatasetMode}">
          <StackPanel Spacing="12">
            <TextBlock Text="Save Settings" FontWeight="SemiBold" FontSize="14"/>
            <ComboBox ItemsSource="{Binding AvailableSaveModes}"
                      SelectedItem="{Binding SaveMode}"
                      HorizontalAlignment="Stretch">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Converter={x:Static converters:UpscaleEnumDisplayConverter.Instance}}"/>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding SaveModeDescription}"
                       TextWrapping="Wrap"
                       Opacity="0.5" FontSize="11" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>

        <!-- Action & Status -->
        <Border Background="#333333" CornerRadius="8" Padding="16">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <Button Grid.Column="0"
                      Content="Start Upscale"
                      Command="{Binding StartUpscaleCommand}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      Padding="12,8"
                      FontWeight="SemiBold"
                      Background="#4CAF50"
                      Foreground="White"/>
              <Button Grid.Column="1"
                      Content="Cancel"
                      Command="{Binding CancelUpscaleCommand}"
                      Margin="8,0,0,0"
                      Padding="12,8"
                      IsVisible="{Binding IsProcessing}"/>
            </Grid>

            <!-- Progress -->
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding TotalProgress}"
                         IsVisible="{Binding IsProcessing}"
                         Height="6"/>
            <TextBlock Text="{Binding CurrentProcessingStatus}"
                       Foreground="#4CAF50" FontSize="13"
                       TextWrapping="Wrap"/>

            <!-- ComfyUI unavailable warning -->
            <TextBlock Text="ComfyUI service is not connected. Check your ComfyUI settings."
                       Foreground="#FF5722" FontSize="12"
                       TextWrapping="Wrap"
                       IsVisible="{Binding !IsComfyUIAvailable}"/>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- Right Panel: Overlay Compare + Image Gallery -->
    <Grid Grid.Column="1" RowDefinitions="*,Auto">

      <!-- Before / After Overlay Compare using ImageCompareControl -->
      <Panel Grid.Row="0">
        <controls:ImageCompareControl
            LeftImagePath="{Binding SelectedCompareItem.OriginalPath}"
            RightImagePath="{Binding SelectedCompareItem.UpscaledPath}"
            SliderValue="50"
            IsVisible="{Binding SelectedCompareItem.IsProcessed, FallbackValue=False}"/>

        <!-- Placeholder when no processed image is selected -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    IsVisible="{Binding SelectedCompareItem, Converter={x:Static ObjectConverters.IsNull}}">
          <TextBlock Text="&#x1F5BC;" FontSize="64" Opacity="0.2" HorizontalAlignment="Center"/>
          <TextBlock Text="Select a processed image to compare" Opacity="0.3"
                     HorizontalAlignment="Center" FontSize="14" Margin="0,8,0,0"/>
        </StackPanel>
      </Panel>

      <!-- Image Gallery -->
      <Border Grid.Row="1" Background="#1E1E1E" Padding="8" MaxHeight="200"
              BorderBrush="#333" BorderThickness="0,1,0,0">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Text="Images" FontWeight="SemiBold" Margin="8,0,0,8"/>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding UpscaleItems}"
                   SelectedItem="{Binding SelectedCompareItem}"
                   Background="Transparent">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Background="#333" CornerRadius="4" Padding="4" Margin="2"
                        Width="80" Height="80"
                        BorderThickness="2"
                        Classes.processing="{Binding IsProcessing}"
                        Classes.processed="{Binding IsProcessed}">
                  <Border.Styles>
                    <Style Selector="Border">
                      <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                    <Style Selector="Border.processing">
                      <Setter Property="BorderBrush" Value="#FF9800"/>
                    </Style>
                    <Style Selector="Border.processed">
                      <Setter Property="BorderBrush" Value="#4CAF50"/>
                    </Style>
                  </Border.Styles>
                  <Grid RowDefinitions="*,Auto">
                    <Image Grid.Row="0" Source="{Binding OriginalThumbnail}" Stretch="Uniform"/>
                    <TextBlock Grid.Row="1" Text="{Binding FileName}" FontSize="9"
                               TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                               Opacity="0.7"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</UserControl>