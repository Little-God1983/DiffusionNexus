<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vmTabs="using:DiffusionNexus.UI.ViewModels.Tabs" xmlns:models="using:DiffusionNexus.Domain.Models" mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600" x:Class="DiffusionNexus.UI.Views.Tabs.DuplicateDetectionView" x:DataType="vmTabs:DuplicateDetectionTabViewModel"><Grid RowDefinitions="Auto,*"><Border Grid.Row="0" Background="#1E1E1E" Padding="16,12" BorderBrush="#333" BorderThickness="0,0,0,1"><Grid ColumnDefinitions="*,Auto,Auto"><TextBlock Grid.Column="0" Text="Duplicate Detection" FontSize="14" FontWeight="SemiBold" Opacity="0.8" VerticalAlignment="Center"/><Button Grid.Column="1" Content="Analyze" Command="{Binding AnalyzeCommand}" Padding="14,8" Margin="0,0,8,0" Background="#4CAF50" Foreground="White" FontWeight="SemiBold" CornerRadius="4"/><TextBlock Grid.Column="2" Text="{Binding SummaryText}" FontSize="12" Opacity="0.7" VerticalAlignment="Center" IsVisible="{Binding HasResults}"/></Grid></Border><Grid Grid.Row="1" ColumnDefinitions="300,*"><Border Grid.Column="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="8"><Grid RowDefinitions="Auto,Auto,*"><StackPanel Grid.Row="0" Spacing="4" Margin="8,8,8,12" IsVisible="{Binding HasResults}"><TextBlock FontSize="12" Opacity="0.7" Text="{Binding TotalImagesScanned, StringFormat=Total images: {0}}"/><TextBlock FontSize="12" Opacity="0.7" Text="{Binding ExactDuplicateCount, StringFormat=Exact duplicate groups: {0}}"/><TextBlock FontSize="12" Opacity="0.7" Text="{Binding NearDuplicateCount, StringFormat=Near-duplicate groups: {0}}"/></StackPanel><TextBlock Grid.Row="1" Text="Issues" FontSize="13" FontWeight="SemiBold" Opacity="0.6" Margin="8,0,8,6"/><TextBlock Grid.Row="2" Text="Run analysis to detect duplicates" FontSize="12" Opacity="0.4" Margin="8" IsVisible="{Binding !HasResults}"/></Grid></Border><ScrollViewer Grid.Column="1" Padding="12"><StackPanel Spacing="8"><TextBlock Text="No results yet. Click Analyze to scan for duplicates." FontSize="13" Opacity="0.4" Margin="8" IsVisible="{Binding !HasResults}"/><ItemsControl ItemsSource="{Binding Clusters}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="vmTabs:DuplicateClusterItemViewModel"><Border Background="#222" CornerRadius="6" Padding="12" Margin="0,0,0,8"><StackPanel Spacing="8"><Grid ColumnDefinitions="Auto,*,Auto"><StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding SeverityIcon}" FontSize="14" VerticalAlignment="Center"/><TextBlock Text="{Binding GroupLabel}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding SimilarityDisplay}" FontSize="11" Opacity="0.6" VerticalAlignment="Center" HorizontalAlignment="Center"/><Button Grid.Column="2" Command="{Binding ToggleExpandCommand}" Padding="8,4" FontSize="11" CornerRadius="3" Content="Toggle"/></Grid><ItemsControl ItemsSource="{Binding FileNames}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String"><TextBlock Text="{Binding}" FontSize="11" Opacity="0.7" Margin="20,1,0,1"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><ItemsControl ItemsSource="{Binding ImagePaths}" IsVisible="{Binding IsExpanded}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="x:String"><Border Background="#1A1A1A" CornerRadius="4" Padding="4" Margin="4"><Image Source="{Binding}" MaxWidth="160" MaxHeight="160" Stretch="Uniform"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></ScrollViewer></Grid></Grid></UserControl>