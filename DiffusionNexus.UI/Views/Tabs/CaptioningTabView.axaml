<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels.Tabs"
             xmlns:enums="using:DiffusionNexus.Domain.Enums"
             xmlns:svc="using:DiffusionNexus.Domain.Services"
             xmlns:converters="using:DiffusionNexus.UI.Converters"
             xmlns:controls="using:DiffusionNexus.UI.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="DiffusionNexus.UI.Views.Tabs.CaptioningTabView"
             x:DataType="vm:CaptioningTabViewModel">

  <Design.DataContext>
    <vm:CaptioningTabViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="*">

    <!-- Service Unavailable Warning -->
    <Border IsVisible="{Binding IsServiceAvailable, Converter={x:Static converters:BoolConverters.Not}}"
            Background="#1A1A1A" CornerRadius="8" Margin="16" Padding="32"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="16" HorizontalAlignment="Center">
        <TextBlock Text="?" FontSize="64" HorizontalAlignment="Center" Opacity="0.3" Foreground="#FFC107"/>
        <TextBlock Text="Captioning Service Unavailable" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        <TextBlock Text="The AI captioning service is not configured. Ensure the captioning backend is installed and available."
                   Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="400"/>
      </StackPanel>
    </Border>

    <!-- Main Split Layout -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*" IsVisible="{Binding IsServiceAvailable}">

      <!-- LEFT: Settings Panel -->
      <Grid Grid.Column="0" Width="480" RowDefinitions="*,Auto">
      <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Margin="16">

          <!-- Backend Selection -->
          <Border Background="#333333" CornerRadius="8" Padding="16">
            <StackPanel Spacing="12">
              <TextBlock Text="Captioning Backend" FontWeight="SemiBold" FontSize="14"/>

              <ComboBox ItemsSource="{Binding AvailableBackends}"
                        SelectedItem="{Binding SelectedBackend}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="svc:ICaptioningBackend">
                    <TextBlock Text="{Binding DisplayName}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- ComfyUI Readiness Status (unified check) -->
              <controls:ComfyUIReadinessPanel DataContext="{Binding Readiness}"/>

              <!-- Local inference model panel (hidden when ComfyUI is selected) -->
              <StackPanel Spacing="8" IsVisible="{Binding IsLocalInferenceBackend}">
                <Border Height="1" Background="#40FFFFFF" Margin="0,4"/>
                <TextBlock Text="Local Model" FontWeight="SemiBold" FontSize="12" Opacity="0.7"/>
                <ComboBox ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding SelectedModelType}"
                          HorizontalAlignment="Stretch"/>

                <!-- LLaVA Status/Download -->
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding SelectedModelType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static enums:CaptioningModelType.LLaVA_v1_6_34B}}">
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="LLaVA v1.6 34B" FontWeight="Bold"/>
                    <TextBlock Text="{Binding LlavaStatusText}" FontSize="12" Opacity="0.7"/>
                    <ProgressBar Value="{Binding LlavaDownloadProgress}" Maximum="100" Height="2" Margin="0,4,8,0"
                                 IsVisible="{Binding IsLlavaDownloading}"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Download"
                          Command="{Binding DownloadModelCommand}"
                          CommandParameter="{x:Static enums:CaptioningModelType.LLaVA_v1_6_34B}"
                          IsVisible="{Binding IsLlavaMissing}"/>
                  <TextBlock Grid.Column="1" Text="Ready" Foreground="#4CAF50" VerticalAlignment="Center" FontWeight="Bold"
                             IsVisible="{Binding IsLlavaReady}"/>
                </Grid>

                <!-- Qwen 2.5 Status/Download -->
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding SelectedModelType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static enums:CaptioningModelType.Qwen2_5_VL_7B}}">
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Qwen 2.5 VL 7B" FontWeight="Bold"/>
                    <TextBlock Text="{Binding QwenStatusText}" FontSize="12" Opacity="0.7"/>
                    <ProgressBar Value="{Binding QwenDownloadProgress}" Maximum="100" Height="2" Margin="0,4,8,0"
                                 IsVisible="{Binding IsQwenDownloading}"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Download"
                          Command="{Binding DownloadModelCommand}"
                          CommandParameter="{x:Static enums:CaptioningModelType.Qwen2_5_VL_7B}"
                          IsVisible="{Binding IsQwenMissing}"/>
                  <TextBlock Grid.Column="1" Text="Ready" Foreground="#4CAF50" VerticalAlignment="Center" FontWeight="Bold"
                             IsVisible="{Binding IsQwenReady}"/>
                </Grid>

                <!-- Qwen 3 Status/Download -->
                <Grid ColumnDefinitions="*,Auto"
                      IsVisible="{Binding SelectedModelType, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static enums:CaptioningModelType.Qwen3_VL_8B}}">
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Qwen 3 VL 8B" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Qwen3StatusText}" FontSize="12" Opacity="0.7"/>
                    <ProgressBar Value="{Binding Qwen3DownloadProgress}" Maximum="100" Height="2" Margin="0,4,8,0"
                                 IsVisible="{Binding IsQwen3Downloading}"/>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Download"
                          Command="{Binding DownloadModelCommand}"
                          CommandParameter="{x:Static enums:CaptioningModelType.Qwen3_VL_8B}"
                          IsVisible="{Binding IsQwen3Missing}"/>
                  <TextBlock Grid.Column="1" Text="Ready" Foreground="#4CAF50" VerticalAlignment="Center" FontWeight="Bold"
                             IsVisible="{Binding IsQwen3Ready}"/>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Input Selection -->
          <Border Background="#333333" CornerRadius="8" Padding="16">
            <StackPanel Spacing="12">
              <TextBlock Text="Input Source" FontWeight="SemiBold" FontSize="14"/>

              <ToggleSwitch IsChecked="{Binding IsSingleImageMode}"
                            OnContent="Single Image"
                            OffContent="Dataset"
                            HorizontalAlignment="Left"/>

              <!-- Dataset Input -->
              <StackPanel IsVisible="{Binding !IsSingleImageMode}">
                <TextBlock Text="Select Dataset" Margin="0,0,0,4"/>
                <Grid ColumnDefinitions="*,4,Auto">
                  <controls:DatasetVersionSelectorControl Grid.Column="0"
                      Datasets="{Binding AvailableDatasets}"
                      SelectedDataset="{Binding SelectedDataset, Mode=TwoWay}"
                      VersionItems="{Binding AvailableDatasetVersions}"
                      SelectedVersion="{Binding SelectedDatasetVersion, Mode=TwoWay}"
                      IsDatasetSearchable="True"
                      DatasetPlaceholderText="Choose a dataset..."/>

                  <Button Grid.Column="2" Content="&#x21BB;"
                          Command="{Binding RefreshDatasetsCommand}"
                          Padding="8,6"
                          ToolTip.Tip="Refresh dataset list"/>
                </Grid>
              </StackPanel>

              <!-- Single Image Input -->
              <StackPanel IsVisible="{Binding IsSingleImageMode}" Spacing="8">
                <!-- Drop zone (no image loaded) -->
                <Border x:Name="SingleImageDropZone"
                        Background="#1A1A1A" BorderBrush="#444" BorderThickness="2"
                        CornerRadius="8" Padding="16" MinHeight="100"
                        DragDrop.AllowDrop="True"
                        IsVisible="{Binding !HasSingleImage}">
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="No image loaded" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Opacity="0.6"/>
                    <TextBlock Text="Drag and drop an image here"
                               FontSize="12" Opacity="0.4" HorizontalAlignment="Center"/>
                    <TextBlock Text="or use 'Send to Captioning' from Dataset Management"
                               FontSize="11" Opacity="0.3" HorizontalAlignment="Center"/>
                    <Button Content="+ Open Image"
                            Command="{Binding SelectSingleImageCommand}"
                            HorizontalAlignment="Center"
                            Background="#4CAF50" Foreground="White"
                            Padding="12,6" Margin="0,4,0,0"/>
                  </StackPanel>
                </Border>

                <!-- Loaded image info (image loaded) -->
                <Border Background="#1A1A1A" CornerRadius="8" Padding="12"
                        IsVisible="{Binding HasSingleImage}"
                        DragDrop.AllowDrop="True"
                        x:Name="SingleImageLoadedZone">
                  <Grid ColumnDefinitions="Auto,8,*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="&#x1F5BC;" FontSize="20" VerticalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Grid.Column="2" Text="{Binding SingleImageName}"
                               FontSize="13" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Opacity="0.8"/>
                    <Button Grid.Column="3" Content="..."
                            Command="{Binding SelectSingleImageCommand}"
                            Padding="8,4" Margin="4,0,0,0"
                            ToolTip.Tip="Choose a different image"/>
                    <Button Grid.Column="4" Content="X"
                            Command="{Binding ClearSingleImageCommand}"
                            Padding="8,4" Margin="4,0,0,0"
                            Foreground="#FF6B6B" FontWeight="Bold"
                            ToolTip.Tip="Remove image"/>
                  </Grid>
                </Border>

                <!-- Compare toggle (visible when single image has an existing caption) -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding SingleImageHasExistingCaption}">
                  <ToggleSwitch IsChecked="{Binding IsCompareMode}"
                                OnContent="Compare On"
                                OffContent="Compare Off"
                                HorizontalAlignment="Left"
                                ToolTip.Tip="When enabled, shows a side-by-side comparison of the current and newly generated caption after generation"/>
                  <TextBlock Text="Existing caption found"
                             FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Captioning Settings -->
          <Border Background="#333333" CornerRadius="8" Padding="16">
            <StackPanel Spacing="12">
              <TextBlock Text="Captioning Settings" FontWeight="SemiBold" FontSize="14"/>

              <!-- System Prompt -->
              <StackPanel Margin="0,0,0,4" Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="System Prompt" VerticalAlignment="Center"/>
                  <ToggleSwitch Grid.Column="1"
                                IsChecked="{Binding IsCustomPromptMode}"
                                OnContent="Custom"
                                OffContent="Preset"
                                HorizontalAlignment="Right"/>
                </Grid>

                <!-- Preset Dropdown (visible when NOT in custom mode) -->
                <ComboBox ItemsSource="{Binding PresetPrompts}"
                          SelectedItem="{Binding SelectedPresetPrompt}"
                          HorizontalAlignment="Stretch"
                          IsVisible="{Binding !IsCustomPromptMode}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Custom Prompt TextBox (visible when in custom mode) -->
                <TextBox Text="{Binding SystemPrompt}" AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                         IsVisible="{Binding IsCustomPromptMode}"/>
              </StackPanel>

              <Grid ColumnDefinitions="*,16,*">
                <!-- Trigger Word -->
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Trigger Word (Optional)" Margin="0,0,0,4"/>
                  <TextBox Text="{Binding TriggerWord}" Watermark="e.g. ohwx style"/>
                </StackPanel>

                <!-- Blacklisted Words -->
                <StackPanel Grid.Column="2">
                  <TextBlock Text="Blacklisted Words (Optional, comma sep)" Margin="0,0,0,4"/>
                  <TextBox Text="{Binding BlacklistedWords}" Watermark="text, watermark, signature"/>
                </StackPanel>
              </Grid>

              <Grid ColumnDefinitions="*,16,*">
                <!-- Temperature -->
                <StackPanel Grid.Column="0">
                  <TextBlock Text="{Binding Temperature, StringFormat='Temperature: {0:F1}'}" Margin="0,0,0,4"/>
                  <Slider Value="{Binding Temperature}" Minimum="0.1" Maximum="2.0"
                          TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                </StackPanel>

                <!-- Override Option -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                  <CheckBox Content="Override Existing Captions" IsChecked="{Binding OverrideExisting}"/>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Save Settings (dataset mode only) -->
          <Border Background="#333333" CornerRadius="8" Padding="16"
                  IsVisible="{Binding !IsSingleImageMode}">
            <StackPanel Spacing="12">
              <TextBlock Text="Save Settings" FontWeight="SemiBold" FontSize="14"/>
              <ComboBox ItemsSource="{Binding AvailableSaveModes}"
                        SelectedItem="{Binding SaveMode}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={x:Static converters:UpscaleEnumDisplayConverter.Instance}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="{Binding SaveModeDescription}"
                         TextWrapping="Wrap"
                         Opacity="0.5" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
          </Border>

          <!-- Dataset Statistics -->
          <Border Background="#333333" CornerRadius="8" Padding="16"
                  IsVisible="{Binding HasDatasetStats}">
            <StackPanel Spacing="10">
              <TextBlock Text="Dataset Overview" FontWeight="SemiBold" FontSize="14"/>

              <!-- Progress bar showing captioned ratio -->
              <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                <ProgressBar Grid.Row="0" Grid.ColumnSpan="2"
                             Value="{Binding DatasetCaptionedCount}" Maximum="{Binding DatasetImageCount}"
                             Height="6" CornerRadius="3" Margin="0,0,0,8"/>

                <!-- Stats row -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="16">
                  <StackPanel>
                    <TextBlock Text="Total Images" FontSize="11" Opacity="0.5"/>
                    <TextBlock Text="{Binding DatasetImageCount}" FontSize="18" FontWeight="Bold"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="Captioned" FontSize="11" Opacity="0.5"/>
                    <TextBlock Text="{Binding DatasetCaptionedCount}" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                  </StackPanel>
                  <StackPanel>
                    <TextBlock Text="Remaining" FontSize="11" Opacity="0.5"/>
                    <TextBlock Text="{Binding DatasetUncaptionedCount}" FontSize="18" FontWeight="Bold" Foreground="#FF9800"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </StackPanel>
          </Border>

            </StackPanel>
          </ScrollViewer>

          <!-- Action & Status (pinned at bottom, always visible) -->
          <Border Grid.Row="1" Background="#333333" CornerRadius="8" Padding="16" Margin="16,4,16,8">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto">
                <Button Grid.Column="0"
                        Content="Generate Captions"
                        Command="{Binding GenerateCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="12,8"
                        FontWeight="SemiBold"
                        Background="#4CAF50"
                        Foreground="White"/>
                <Button Grid.Column="1"
                        Content="Pause"
                        Command="{Binding PauseCommand}"
                        Margin="8,0,0,0"
                        Padding="12,8"
                        IsVisible="{Binding IsProcessing}"/>
              </Grid>

              <!-- Progress -->
              <ProgressBar Minimum="0" Maximum="100"
                           Value="{Binding TotalProgress}"
                           IsVisible="{Binding IsProcessing}"
                           Height="6"/>
              <TextBlock Text="{Binding CurrentProcessingStatus}"
                         Foreground="#4CAF50" FontSize="13"
                         TextWrapping="Wrap"
                         IsVisible="{Binding CurrentProcessingStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

              <!-- Status Message -->
              <TextBlock Text="{Binding StatusMessage}"
                         Foreground="#D4A574"
                         TextWrapping="Wrap"
                         IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </StackPanel>
          </Border>
          </Grid>

      <!-- RIGHT: Preview Panel + Gallery -->
      <Grid Grid.Column="1" RowDefinitions="*,Auto,Auto"
            IsVisible="{Binding IsServiceAvailable}">

        <!-- Main Image Preview -->
        <Panel Grid.Row="0">
          <!-- Selected image large preview -->
          <Image Source="{Binding SelectedGalleryPreview}"
                 Stretch="Uniform"
                 IsVisible="{Binding SelectedHistoryItem, Converter={x:Static ObjectConverters.IsNotNull}}"/>

          <!-- Currently processing image (shown when no selection) -->
          <Image Source="{Binding CurrentImagePreview}"
                 Stretch="Uniform">
            <Image.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="SelectedHistoryItem" Converter="{x:Static ObjectConverters.IsNull}"/>
                <Binding Path="CurrentImagePath" Converter="{x:Static ObjectConverters.IsNotNull}"/>
              </MultiBinding>
            </Image.IsVisible>
          </Image>

          <!-- Label overlay for currently processing -->
          <Border Background="#88000000" CornerRadius="4" Padding="8,4"
                  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
            <Border.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="SelectedHistoryItem" Converter="{x:Static ObjectConverters.IsNull}"/>
                <Binding Path="CurrentImagePath" Converter="{x:Static ObjectConverters.IsNotNull}"/>
              </MultiBinding>
            </Border.IsVisible>
            <TextBlock Text="Currently Processing" FontSize="11" Opacity="0.9"/>
          </Border>

          <!-- Placeholder when no image at all -->
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.IsVisible>
              <MultiBinding Converter="{x:Static BoolConverters.And}">
                <Binding Path="SelectedHistoryItem" Converter="{x:Static ObjectConverters.IsNull}"/>
                <Binding Path="CurrentImagePath" Converter="{x:Static ObjectConverters.IsNull}"/>
              </MultiBinding>
            </StackPanel.IsVisible>
            <TextBlock Text="&#x1F5BC;" FontSize="64" Opacity="0.2" HorizontalAlignment="Center"/>
            <TextBlock Text="Select an image to preview" Opacity="0.3"
                       HorizontalAlignment="Center" FontSize="14" Margin="0,8,0,0"/>
          </StackPanel>
        </Panel>

        <!-- Caption Editor (visible when a completed item is selected) -->
        <Border Grid.Row="1" Margin="16,8,16,0" Padding="12" Background="#222222" CornerRadius="6"
                MinHeight="60" MaxHeight="160">
          <Border.IsVisible>
            <MultiBinding Converter="{x:Static BoolConverters.And}">
              <Binding Path="SelectedHistoryItem" Converter="{x:Static ObjectConverters.IsNotNull}"/>
              <Binding Path="SelectedHistoryItem.IsCaptionCompleted"/>
            </MultiBinding>
          </Border.IsVisible>
          <controls:CaptionEditorControl DataContext="{Binding SelectedHistoryItem}"
                Text="{Binding EditableCaption, Mode=TwoWay}"
                HasUnsavedChanges="{Binding HasUnsavedChanges}"
                UndoCommand="{Binding UndoCaptionCommand}"
                RedoCommand="{Binding RedoCaptionCommand}"
                ResetCommand="{Binding RevertCaptionCommand}"
                SaveCommand="{Binding SaveCaptionCommand}"
                Watermark="Caption text..."
                TextMinHeight="50" TextMaxHeight="100"/>
        </Border>

        <!-- Bottom Image Gallery -->
        <Border Grid.Row="2" Background="#1E1E1E" Padding="8" MaxHeight="200"
                BorderBrush="#333" BorderThickness="0,1,0,0">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Text="Images" FontWeight="SemiBold" Margin="8,0,0,8"/>
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding CaptionHistory}"
                     SelectedItem="{Binding SelectedHistoryItem}"
                     Background="Transparent">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:CaptionHistoryItemViewModel">
                  <Border Background="#333" CornerRadius="4" Padding="4" Margin="2"
                          Width="80" Height="80"
                          BorderThickness="2"
                          Classes.processing="{Binding IsProcessing}"
                          Classes.completed="{Binding IsCaptionCompleted}">
                    <Border.Styles>
                      <Style Selector="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                      </Style>
                      <Style Selector="Border.processing">
                        <Setter Property="BorderBrush" Value="#FF9800"/>
                      </Style>
                      <Style Selector="Border.completed">
                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                      </Style>
                    </Border.Styles>
                    <Grid RowDefinitions="*,Auto">
                      <Image Grid.Row="0" Source="{Binding Thumbnail}" Stretch="Uniform"/>
                      <TextBlock Grid.Row="1" Text="{Binding FileName}" FontSize="9"
                                 TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"
                                 Opacity="0.7"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>
    </Grid>

  </Grid>
</UserControl>
