<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="800"
             x:Class="DiffusionNexus.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
  
  <Design.DataContext>
    <vm:SettingsViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*,Auto">
    
    <!-- Fixed Header Area -->
    <StackPanel Grid.Row="0" Spacing="16" Margin="20,20,20,0">
      <!-- Header -->
      <TextBlock Text="Settings" 
                 FontSize="28" 
                 FontWeight="Bold"/>

      <!-- Status Message -->
      <Border Background="#2D7D46" 
              CornerRadius="4" 
              Padding="12,8"
              IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <TextBlock Text="{Binding StatusMessage}" Foreground="White"/>
      </Border>
    </StackPanel>

    <!-- Scrollable Content Area -->
    <ScrollViewer Grid.Row="1" Padding="20">
      <StackPanel Spacing="16" Width="700" HorizontalAlignment="Left">
        
        <!-- General Settings -->
        <Expander Header="General" IsExpanded="False" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="12">
              
              <!-- Civitai API Key -->
              <StackPanel Spacing="4">
                <TextBlock Text="Civitai API Key" FontWeight="SemiBold"/>
                <TextBlock Text="Required for downloading model metadata. Get your key from civitai.com/user/account" 
                           FontSize="12" 
                           Opacity="0.7"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           PasswordChar="*" 
                           Watermark="Paste your API key here"
                           Text="{Binding CivitaiApiKey, Mode=TwoWay}"/>
                  <Button Grid.Column="1" 
                          Content="Clear" 
                          Command="{Binding DeleteApiKeyCommand}"
                          Margin="8,0,0,0"/>
                </Grid>
              </StackPanel>

              <!-- Huggingface API Key -->
              <StackPanel Spacing="4">
                <TextBlock Text="Huggingface API Key" FontWeight="SemiBold"/>
                <TextBlock Text="Required for downloading models from Huggingface. Get your key from huggingface.co/settings/tokens" 
                           FontSize="12" 
                           Opacity="0.7"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           PasswordChar="*" 
                           Watermark="Paste your API key here"
                           Text="{Binding HuggingfaceApiKey, Mode=TwoWay}"/>
                  <Button Grid.Column="1" 
                          Content="Clear" 
                          Command="{Binding DeleteHuggingfaceApiKeyCommand}"
                          Margin="8,0,0,0"/>
                </Grid>
              </StackPanel>

              <!-- Civitai Base Model Catalog refresh -->
              <StackPanel Spacing="4">
                <TextBlock Text="Civitai Base Model Definition" FontWeight="SemiBold"/>
                <TextBlock Text="Refreshes the list of base models used by the LoRA detail dropdown. Fetches the latest definition from Civitai's GitHub repo and updates the local cache. Status is reported in the Unified Console."
                           FontSize="12"
                           Opacity="0.7"
                           TextWrapping="Wrap"/>
                <Button Content="Refresh base model definition"
                        Command="{Binding RefreshBaseModelCatalogCommand}"
                        HorizontalAlignment="Left"/>
              </StackPanel>

              <!-- Separator -->
              <Border Height="1" Background="#40FFFFFF" Margin="0,4"/>

              <!-- Backup (moved here from the LoRA Dataset Helper section) -->
              <StackPanel Spacing="8">
                <TextBlock Text="Backup" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Automatically back up your data at a regular interval. Choose what to include below. The backup location cannot be the same as or a subfolder of the Dataset Storage folder."
                           FontSize="12"
                           Opacity="0.7"
                           TextWrapping="Wrap"/>

                <!-- What to back up -->
                <CheckBox Content="Back up dataset images"
                          IsChecked="{Binding BackupDatasetImagesEnabled, Mode=TwoWay}"
                          ToolTip.Tip="Zip the LoRA training dataset folders into the backup location"/>
                <CheckBox Content="Back up database"
                          IsChecked="{Binding BackupDatabaseEnabled, Mode=TwoWay}"
                          ToolTip.Tip="Copy the core user database (models, settings, galleries) into the backup location"/>

                <!-- Backup Interval -->
                <StackPanel Spacing="4" IsEnabled="{Binding AnyBackupEnabled}">
                  <TextBlock Text="Backup Interval" FontWeight="SemiBold"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding AvailableBackupDays}"
                              SelectedItem="{Binding AutoBackupIntervalDays, Mode=TwoWay}"
                              Width="80"/>
                    <TextBlock Text="Days" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding AvailableBackupHours}"
                              SelectedItem="{Binding AutoBackupIntervalHours, Mode=TwoWay}"
                              Width="80"
                              Margin="16,0,0,0"/>
                    <TextBlock Text="Hours" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Text="{Binding AutoBackupIntervalError}"
                             Foreground="#FF6B6B"
                             FontSize="12"
                             TextWrapping="Wrap"
                             IsVisible="{Binding AutoBackupIntervalError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <!-- Max Backups -->
                <StackPanel Spacing="4" IsEnabled="{Binding AnyBackupEnabled}">
                  <TextBlock Text="Maximum Backups (per type)" FontWeight="SemiBold"/>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <ComboBox ItemsSource="{Binding AvailableMaxBackups}"
                              SelectedItem="{Binding MaxBackups, Mode=TwoWay}"
                              Width="80"/>
                    <TextBlock Text="(oldest backups will be deleted when exceeded; applies to each type)"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               FontSize="12"/>
                  </StackPanel>
                </StackPanel>

                <!-- Backup Location -->
                <StackPanel Spacing="4" IsEnabled="{Binding AnyBackupEnabled}">
                  <TextBlock Text="Backup Location" FontWeight="SemiBold"/>
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding AutoBackupLocation, Mode=TwoWay}"
                             Watermark="Select backup folder..."/>
                    <Button Grid.Column="1"
                            Content="Browse..."
                            Command="{Binding BrowseAutoBackupLocationCommand}"
                            Margin="8,0,0,0"/>
                    <Button Grid.Column="2"
                            Content="Open Folder"
                            Command="{Binding OpenBackupLocationFolderCommand}"
                            Margin="4,0,0,0"
                            ToolTip.Tip="Open the backup location folder in file explorer"/>
                  </Grid>
                  <TextBlock Text="{Binding AutoBackupLocationError}"
                             Foreground="#FF6B6B"
                             FontSize="12"
                             TextWrapping="Wrap"
                             IsVisible="{Binding AutoBackupLocationError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>

                <!-- Backup Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                  <Button Content="Backup Now"
                          Command="{Binding BackupNowCommand}"
                          IsEnabled="{Binding !IsBackupInProgress}"
                          Padding="12,8"
                          ToolTip.Tip="Run a backup immediately for everything enabled above"/>
                  <Button Content="Load Backup"
                          Command="{Binding LoadBackupCommand}"
                          IsEnabled="{Binding !IsBackupInProgress}"
                          Padding="12,8"
                          ToolTip.Tip="Select and restore a dataset image backup file"/>
                </StackPanel>

                <!-- Current Database Location -->
                <StackPanel Spacing="4" Margin="0,8,0,0">
                  <TextBlock Text="Current database location" FontWeight="SemiBold"/>
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             Text="{Binding DatabaseFilePath, Mode=OneWay}"
                             IsReadOnly="True"
                             ToolTip.Tip="{Binding DatabaseFilePath}"/>
                    <Button Grid.Column="1"
                            Content="Open Folder"
                            Command="{Binding OpenDatabaseFolderCommand}"
                            Margin="8,0,0,0"
                            ToolTip.Tip="Open the folder containing the database file"/>
                  </Grid>
                </StackPanel>

                <!-- Restore info box -->
                <Border Background="#33569CD6"
                        BorderBrush="#569CD6"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12"
                        Margin="0,4,0,0">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Restoring the database" FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="12"
                               Opacity="0.9"
                               Text="Only backup is automated for the database. To restore, fully close DiffusionNexus, then copy your chosen DatabaseBackup_*.db over the database file shown above (delete any -wal / -shm files next to it), and start the app again. Restoring from inside the app is intentionally not supported: replacing the database while it is open (WAL mode) risks corrupting it. Dataset image backups can be restored any time with 'Load Backup' above."/>
                  </StackPanel>
                </Border>
              </StackPanel>

            </StackPanel>
          </Border>
        </Expander>

        <!-- LoRA Viewer -->
        <Expander Header="LoRA Viewer" IsExpanded="False" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="16">
              <StackPanel Spacing="8">
                <TextBlock Text="Source Folders" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Folders containing your LoRA models. All subfolders will be scanned." 
                           FontSize="12" 
                           Opacity="0.7"/>
                <Button Content="+ Add Source Folder" 
                        Command="{Binding AddLoraSourceCommand}"
                        HorizontalAlignment="Left"/>
                <ItemsControl ItemsSource="{Binding LoraSources}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:LoraSourceViewModel">
                      <Border Background="#20FFFFFF"
                              CornerRadius="4"
                              Padding="12"
                              Margin="0,4">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                          <CheckBox Grid.Column="0"
                                    IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Enable/disable this source"/>
                          <!-- Favorite star — clicking sets this source as the default
                               destination for new downloads (Installed tab dialog and
                               Civitai browser queue). Only one source can be the favorite. -->
                          <ToggleButton Grid.Column="1"
                                        IsChecked="{Binding IsFavorite, Mode=TwoWay}"
                                        VerticalAlignment="Center"
                                        Margin="6,0"
                                        Padding="6,4"
                                        ToolTip.Tip="Set as favorite — pre-selected in download dialogs">
                            <Panel>
                              <!-- Yellow filled star when checked, faded outline when not. -->
                              <TextBlock Text="&#x2605;" FontSize="14" Foreground="#FBBF24"
                                         IsVisible="{Binding IsFavorite}"/>
                              <TextBlock Text="&#x2606;" FontSize="14" Foreground="#888888"
                                         IsVisible="{Binding !IsFavorite}"/>
                            </Panel>
                          </ToggleButton>
                          <TextBox Grid.Column="2"
                                   Text="{Binding FolderPath, Mode=TwoWay}"
                                   Watermark="Enter folder path..."
                                   Margin="8,0"/>
                          <Button Grid.Column="3"
                                  Content="Browse..."
                                  Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).BrowseLoraSourceCommand}"
                                  CommandParameter="{Binding}"
                                  Margin="0,0,8,0"/>
                          <Button Grid.Column="4"
                                  Content="X"
                                  FontWeight="Bold"
                                  Foreground="#FF6B6B"
                                  Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveLoraSourceCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Remove this source"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>
              <StackPanel Spacing="8">
                <TextBlock Text="Display Options" FontWeight="SemiBold" FontSize="14"/>
                <CheckBox Content="Show NSFW content by default"
                          IsChecked="{Binding ShowNsfw, Mode=TwoWay}"/>
                <CheckBox Content="Automatic thumbnail generation from videos"
                          IsChecked="{Binding GenerateVideoThumbnails, Mode=TwoWay}"/>
                <CheckBox Content="Show video preview (experimental, slower)"
                          IsChecked="{Binding ShowVideoPreview, Mode=TwoWay}"/>
                <CheckBox Content="A1111/Forge style prompts"
                          IsChecked="{Binding UseForgeStylePrompts, Mode=TwoWay}"/>
                      <CheckBox Content="Merge LoRA sources by base model (experimental)"
                                  IsChecked="{Binding MergeLoraSources, Mode=TwoWay}"/>
                      </StackPanel>
                      <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>
                      <StackPanel Spacing="8">
                        <TextBlock Text="Civitai Update Check" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Re-check Civitai for new versions of the LoRAs currently on screen when their last check is older than this. Set to 0 to disable. Only visible tiles are checked, with rate-limit handling."
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <ComboBox ItemsSource="{Binding AvailableLoraUpdateCheckStalenessDays}"
                                    SelectedItem="{Binding LoraUpdateCheckStalenessDays, Mode=TwoWay}"
                                    Width="80"/>
                          <TextBlock Text="Days (0 = disabled)" VerticalAlignment="Center"/>
                        </StackPanel>
                      </StackPanel>
                      <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>
                      <StackPanel Spacing="8">
                        <TextBlock Text="Base Model Filter" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Force-updates the base-model filter list shared by the Installed and Browse Civitai tabs. Fetches the latest base-model definition from Civitai and rebuilds the filter immediately, without an app restart. Status is reported in the Unified Console."
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextWrapping="Wrap"/>
                        <Button Content="Update Installed &amp; Browse Civitai filter"
                                Command="{Binding RefreshBaseModelCatalogCommand}"
                                HorizontalAlignment="Left"/>
                      </StackPanel>
                      <Border Height="1" Background="#40FFFFFF" Margin="0,8"/>
                      <StackPanel Spacing="8">
                        <TextBlock Text="Database" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="Clear all cached LoRA metadata, thumbnails, and sync data from the database. Your LoRA files on disk and app settings are not affected." 
                                   FontSize="12" 
                                   Opacity="0.7"
                                   TextWrapping="Wrap"/>
                        <Button Content="Reset LoRA Database"
                                Command="{Binding ResetLoraDatabaseCommand}"
                                Foreground="#FF6B6B"
                                HorizontalAlignment="Left"/>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </Expander>

        <!-- Generation Galleries -->
        <Expander Header="Generation Galleries" IsExpanded="False" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="16">
              
              <!-- Source Folders Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="Generation Gallery Folders" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Folders containing images and videos to display in the Generation Gallery." 
                           FontSize="12" 
                           Opacity="0.7"/>
                
                <!-- Add Button -->
                <Button Content="+ Add Generation Gallery Folder" 
                        Command="{Binding AddImageGallerySourceCommand}"
                        HorizontalAlignment="Left"/>
                
                <!-- Source List -->
                <ItemsControl ItemsSource="{Binding ImageGallerySources}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ImageGalleryViewModel">
                      <Border Background="#20FFFFFF"
                              CornerRadius="4"
                              Padding="12"
                              Margin="0,4">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                          
                          <!-- Enabled Checkbox -->
                          <CheckBox Grid.Column="0"
                                    IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Enable/disable this gallery"/>
                          
                          <!-- Path -->
                          <TextBox Grid.Column="1"
                                   Text="{Binding FolderPath, Mode=TwoWay}"
                                   Watermark="Enter folder path..."
                                   Margin="8,0"/>
                          
                          <!-- Browse Button -->
                          <Button Grid.Column="2"
                                  Content="Browse..."
                                  Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).BrowseImageGallerySourceCommand}"
                                  CommandParameter="{Binding}"
                                  Margin="0,0,8,0"/>
                          
                          <!-- Remove Button -->
                          <Button Grid.Column="3"
                                  Content="X"
                                  FontWeight="Bold"
                                  Foreground="#FF6B6B"
                                  Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveImageGallerySourceCommand}"
                                  CommandParameter="{Binding}"
                                  ToolTip.Tip="Remove this gallery"/>
                          
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              
            </StackPanel>
          </Border>
        </Expander>

        <!-- LoRA Dataset Helper (NEW) -->
        <Expander Header="LoRA Dataset Helper" IsExpanded="True" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="16">
              
              <!-- Dataset Storage Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="Dataset Storage" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Default folder where new LoRA training datasets will be created. Each dataset will be stored as a subfolder within this path." 
                           FontSize="12" 
                           Opacity="0.7"
                           TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBox Grid.Column="0"
                           Text="{Binding DatasetStoragePath, Mode=TwoWay}"
                           Watermark="Select dataset storage folder..."/>
                  <Button Grid.Column="1"
                          Content="Browse..."
                          Command="{Binding BrowseDatasetStorageCommand}"
                          Margin="8,0,0,0"/>
                  <Button Grid.Column="2"
                          Content="Open Folder"
                          Command="{Binding OpenDatasetStorageFolderCommand}"
                          Margin="4,0,0,0"
                          ToolTip.Tip="Open the dataset storage folder in file explorer"/>
                </Grid>
              </StackPanel>

              <!-- Separator -->
              <Border Height="1" Background="#40FFFFFF" Margin="0,4"/>

              <!-- Dataset Categories Section -->
              <StackPanel Spacing="8">
                <TextBlock Text="Dataset Categories" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="Categories for organizing your training datasets. Default categories (Character, Style, Concept) cannot be deleted." 
                           FontSize="12" 
                           Opacity="0.7"
                           TextWrapping="Wrap"/>
                
                <!-- Add Button -->
                <Button Content="+ Add Category" 
                        Command="{Binding AddCategoryCommand}"
                        HorizontalAlignment="Left"/>
                
                <!-- Category List -->
                <ItemsControl ItemsSource="{Binding DatasetCategories}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DatasetCategoryViewModel">
                      <Border Background="#20FFFFFF"
                              CornerRadius="4"
                              Padding="12"
                              Margin="0,4">
                        <Grid ColumnDefinitions="*,*,Auto">
                          
                          <!-- Name -->
                          <TextBox Grid.Column="0"
                                   Text="{Binding Name, Mode=TwoWay}"
                                   Watermark="Category name..."
                                   IsReadOnly="{Binding IsDefault}"
                                   Margin="0,0,8,0"/>
                          
                          <!-- Description -->
                          <TextBox Grid.Column="1"
                                   Text="{Binding Description, Mode=TwoWay}"
                                   Watermark="Optional description..."
                                   Margin="0,0,8,0"/>
                          
                          <!-- Remove Button (hidden for defaults) -->
                          <Button Grid.Column="2"
                                  Content="X"
                                  FontWeight="Bold"
                                  Foreground="#FF6B6B"
                                  Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveCategoryCommand}"
                                  CommandParameter="{Binding}"
                                  IsVisible="{Binding !IsDefault}"
                                  ToolTip.Tip="Remove this category"/>
                          
                          <!-- Lock icon for defaults -->
                          <TextBlock Grid.Column="2"
                                     Text="[Locked]"
                                     FontSize="10"
                                     VerticalAlignment="Center"
                                     Opacity="0.5"
                                     IsVisible="{Binding IsDefault}"
                                     ToolTip.Tip="Default category - cannot be deleted"/>
                          
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
              
            </StackPanel>
          </Border>
        </Expander>

        <!-- ComfyUI Server -->
        <Expander Header="ComfyUI Server" IsExpanded="False" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="12">

              <TextBlock Text="Configure the URL of your ComfyUI server instance."
                         FontSize="12"
                         Opacity="0.7"/>

              <!-- Server URL -->
              <StackPanel Spacing="4">
                <TextBlock Text="Server URL" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">

                  <!-- Status indicator: green when online, red when offline -->
                  <Panel Grid.Column="0"
                         Width="12" Height="12"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0">
                    <Ellipse Width="12" Height="12"
                             Fill="#2D7D46"
                             IsVisible="{Binding IsComfyUiServerOnline}"/>
                    <Ellipse Width="12" Height="12"
                             Fill="#FF6B6B"
                             IsVisible="{Binding !IsComfyUiServerOnline}"/>
                  </Panel>

                  <TextBox Grid.Column="1"
                           Text="{Binding ComfyUiServerUrl, Mode=TwoWay}"
                           Watermark="http://127.0.0.1:8188/"/>

                  <!-- Test Connection -->
                  <Button Grid.Column="2"
                          Content="Test Connection"
                          Command="{Binding TestComfyUiConnectionCommand}"
                          IsEnabled="{Binding !IsTestingComfyUiConnection}"
                          Margin="8,0,0,0"/>
                </Grid>

                <!-- Testing indicator -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            IsVisible="{Binding IsTestingComfyUiConnection}">
                  <ProgressBar IsIndeterminate="True" Width="100" Height="4"/>
                  <TextBlock Text="Testing connection..." FontSize="12" Opacity="0.7"/>
                </StackPanel>
              </StackPanel>

            </StackPanel>
          </Border>
        </Expander>

        <!-- LoRA Sort settings � hidden until the LoRA Sort module is integrated.
             Do NOT remove; the ViewModel logic is still in place and will be re-enabled. -->
        <!--
        <Expander Header="LoRA Sort" IsExpanded="False" HorizontalAlignment="Stretch">
          <Border Padding="16">
            <StackPanel Spacing="12">
              <TextBlock Text="Default folders for the LoRA Sort tool." 
                         FontSize="12" 
                         Opacity="0.7"/>
              <StackPanel Spacing="4">
                <TextBlock Text="Source Folder" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           Text="{Binding LoraSortSourcePath, Mode=TwoWay}"
                           Watermark="Select source folder..."/>
                  <Button Grid.Column="1"
                          Content="Browse..."
                          Command="{Binding BrowseLoraSortSourceCommand}"
                          Margin="8,0,0,0"/>
                </Grid>
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Text="Target Folder" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           Text="{Binding LoraSortTargetPath, Mode=TwoWay}"
                           Watermark="Select target folder..."/>
                  <Button Grid.Column="1"
                          Content="Browse..."
                          Command="{Binding BrowseLoraSortTargetCommand}"
                          Margin="8,0,0,0"/>
                </Grid>
              </StackPanel>
            </StackPanel>
          </Border>
        </Expander>
        -->

      </StackPanel>
    </ScrollViewer>

    <!-- Fixed Footer with Save Button -->
    <Border Grid.Row="2" 
            Background="#252526" 
            BorderBrush="#333" 
            BorderThickness="0,1,0,0"
            Padding="20,16">
      <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
          <Button Content="Export Settings"
                  Command="{Binding ExportSettingsCommand}"
                  ToolTip.Tip="Export all settings to a JSON file"/>
          <Button Content="Import Settings"
                  Command="{Binding ImportSettingsCommand}"
                  ToolTip.Tip="Import settings from a JSON file (replaces current settings)"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
          
          <TextBlock Text="Unsaved changes"
                     VerticalAlignment="Center"
                     Foreground="Orange"
                     IsVisible="{Binding HasChanges}"/>
          
          <Button Content="Save Settings"
                  Command="{Binding SaveCommand}"
                  MinWidth="120"
                  Classes="accent"/>
          
        </StackPanel>
      </Grid>
    </Border>

    <!-- Busy Overlay -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            Background="#80000000"
            IsVisible="{Binding IsBusy}"
            IsHitTestVisible="{Binding IsBusy}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <ProgressBar IsIndeterminate="True" Width="200"/>
        <TextBlock Text="{Binding BusyMessage}" 
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
