<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DiffusionNexus.UI.ViewModels.CivitaiBrowser"
             xmlns:vmRoot="using:DiffusionNexus.UI.ViewModels"
             xmlns:svc="using:DiffusionNexus.UI.Services.CivitaiBrowser"
             x:Class="DiffusionNexus.UI.Views.CivitaiBrowser.CivitaiBrowserView"
             x:DataType="vm:CivitaiBrowserViewModel">

  <Design.DataContext>
    <vm:CivitaiBrowserViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- Filter bar -->
    <Border Grid.Row="0"
            Background="#161616"
            Padding="12,8"
            BorderBrush="#2A2A2A"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto">

        <StackPanel Grid.Column="0" Margin="0,0,16,0">
          <TextBlock Text="Sort" Opacity="0.6" FontSize="11"/>
          <ComboBox ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSort, Mode=TwoWay}"
                    MinWidth="140"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="0,0,16,0">
          <TextBlock Text="Period" Opacity="0.6" FontSize="11"/>
          <ComboBox ItemsSource="{Binding PeriodOptions}"
                    SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                    MinWidth="110"/>
        </StackPanel>

        <StackPanel Grid.Column="2" Margin="0,0,16,0">
          <TextBlock Text="Model Type" Opacity="0.6" FontSize="11"/>
          <ComboBox ItemsSource="{Binding ModelTypeOptions}"
                    SelectedItem="{Binding SelectedModelType, Mode=TwoWay}"
                    MinWidth="100"/>
        </StackPanel>

        <StackPanel Grid.Column="3" Margin="0,0,16,0">
          <TextBlock Text="Base Model" Opacity="0.6" FontSize="11"/>
          <Button Padding="8,6" MinWidth="140"
                  HorizontalContentAlignment="Left"
                  ToolTip.Tip="Filter by base model (mirrors the Installed tab list)">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Filter" VerticalAlignment="Center"/>
              <TextBlock Text="&#x25BD;" FontSize="12"
                         VerticalAlignment="Center"
                         IsVisible="{Binding !IsBaseModelFilterActive}"
                         Foreground="#AAAAAA"/>
              <TextBlock Text="&#x25BD;" FontSize="12"
                         VerticalAlignment="Center"
                         IsVisible="{Binding IsBaseModelFilterActive}"
                         Foreground="#FF4444"/>
              <TextBlock Text="{Binding ActiveBaseModelFilterCount}"
                         IsVisible="{Binding IsBaseModelFilterActive}"
                         Foreground="#FF4444"
                         FontSize="11"
                         VerticalAlignment="Center"/>
            </StackPanel>
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedLeft"
                      ShowMode="TransientWithDismissOnPointerMoveAway">
                <Border Background="#1E1E1E"
                        BorderBrush="#444"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8"
                        MinWidth="200"
                        MaxHeight="400">
                  <Grid RowDefinitions="Auto,Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="Filter by base model"
                               FontWeight="SemiBold"
                               Margin="4,0,4,8"
                               Opacity="0.7"/>

                    <Button Grid.Row="1"
                            Content="Clear all"
                            Command="{Binding ClearBaseModelFiltersCommand}"
                            IsVisible="{Binding IsBaseModelFilterActive}"
                            Padding="4,2"
                            Margin="4,0,4,8"
                            FontSize="11"
                            HorizontalAlignment="Left"/>

                    <ScrollViewer Grid.Row="2"
                                  MaxHeight="340"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding AvailableBaseModels}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Spacing="2"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vmRoot:BaseModelFilterItem">
                            <ToggleButton IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Left"
                                          Padding="8,6"
                                          Background="Transparent"
                                          BorderThickness="1"
                                          BorderBrush="#333"
                                          CornerRadius="4">
                              <TextBlock Text="{Binding BaseModelRaw}"
                                         FontSize="13"/>
                            </ToggleButton>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Flyout>
            </Button.Flyout>
          </Button>
        </StackPanel>

        <!-- spacer -->

        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,16,0">
          <TextBlock Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center"/>
          <TextBlock Text="Zoom" Opacity="0.7" VerticalAlignment="Center"/>
          <Slider Minimum="160" Maximum="360"
                  Value="{Binding CardWidth, Mode=TwoWay}"
                  Width="120"
                  VerticalAlignment="Center"/>
        </StackPanel>

        <CheckBox Grid.Column="6"
                  Content="Hide Installed"
                  IsChecked="{Binding HideInstalledModels, Mode=TwoWay}"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"/>

        <CheckBox Grid.Column="7"
                  Content="Hide Early Access"
                  IsChecked="{Binding HideEarlyAccessModels, Mode=TwoWay}"
                  VerticalAlignment="Center"
                  Margin="0,0,12,0"/>

        <CheckBox Grid.Column="8"
                  Content="Show NSFW Content"
                  IsChecked="{Binding ShowNsfwContent, Mode=TwoWay}"
                  ToolTip.Tip="Browser-only NSFW filter. Independent from the Installed tab's NSFW toggle."
                  VerticalAlignment="Center"/>

      </Grid>
    </Border>

    <!-- Search + actions bar -->
    <Border Grid.Row="1" Background="#1A1A1A" Padding="12,8" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding SearchText, Mode=TwoWay}"
                 Watermark="Search Civitai (debounced)..."
                 Margin="0,0,12,0"/>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
          <TextBlock Opacity="0.7"
                     ToolTip.Tip="Total models the REST API returned for this query. May differ from civitai.com's web search — the web uses a different index that fuzzy-matches tags + descriptions, not just names.">
            <Run Text="Results: "/>
            <Run Text="{Binding Results.Count}"/>
          </TextBlock>
          <TextBlock Opacity="0.7">
            <Run Text="Selected: "/>
            <Run Text="{Binding SelectedCount}"/>
          </TextBlock>
          <TextBlock Opacity="0.7"
                     IsVisible="{Binding HasHiddenResults}"
                     ToolTip.Tip="Results hidden by 'Hide Installed' or 'Hide Early Access' toggles. Disable those filters to see them.">
            <Run Text="Hidden: "/>
            <Run Text="{Binding HiddenByFilters}" Foreground="#F59E0B"/>
          </TextBlock>
        </StackPanel>

        <Button Grid.Column="2"
                Content="Clear selection"
                Command="{Binding ClearSelectionCommand}"
                IsEnabled="{Binding HasSelection}"
                Margin="0,0,8,0"/>

        <Button Grid.Column="3"
                Content="Add selection to queue"
                Classes="accent"
                Command="{Binding AddSelectionToQueueCommand}"
                IsEnabled="{Binding HasSelection}"/>
      </Grid>
    </Border>

    <!-- Results grid + queue side panel -->
    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">

      <Grid Grid.Column="0" RowDefinitions="*,Auto">

      <ScrollViewer Grid.Row="0" Padding="12">
        <StackPanel>
          <ItemsControl ItemsSource="{Binding Results}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CivitaiResultViewModel">
                <Border Margin="6"
                        Width="{Binding $parent[UserControl].((vm:CivitaiBrowserViewModel)DataContext).CardWidth}"
                        IsVisible="{Binding !IsHidden}"
                        Background="#1E1E1E"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="0">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto">

                    <!-- Preview image -->
                    <Border Grid.Row="0" Height="240" ClipToBounds="True" CornerRadius="6,6,0,0">
                      <Grid>
                        <Image Source="{Binding PreviewImage}" Stretch="UniformToFill"/>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Margin="8"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Top"
                                  Background="#CC000000"/>
                        <StackPanel Orientation="Vertical"
                                    Spacing="4"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="8">
                          <Border IsVisible="{Binding IsInstalled}"
                                  Background="#AA22C55E"
                                  CornerRadius="4"
                                  Padding="6,2">
                            <TextBlock Text="Installed" FontSize="10" Foreground="White"/>
                          </Border>
                          <Border IsVisible="{Binding IsEarlyAccess}"
                                  Background="#AA9333EA"
                                  CornerRadius="4"
                                  Padding="6,2">
                            <TextBlock Text="Early Access" FontSize="10" Foreground="White"/>
                          </Border>
                        </StackPanel>
                        <Border Background="#AA000000"
                                CornerRadius="4"
                                Padding="6,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="8">
                          <TextBlock Text="{Binding BaseModel}" FontSize="11" Foreground="White"/>
                        </Border>
                      </Grid>
                    </Border>

                    <!-- Name -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Name}"
                               FontWeight="SemiBold"
                               Margin="10,8,10,2"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Stats -->
                    <Grid Grid.Row="2" Margin="10,2,10,4" ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding Creator}"
                                 Opacity="0.6"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis"/>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding DownloadCount, StringFormat=&#x2B07; {0:N0}}" FontSize="11" Opacity="0.7"/>
                        <TextBlock Text="{Binding ThumbsUp, StringFormat=&#x1F44D; {0:N0}}" FontSize="11" Opacity="0.7"/>
                      </StackPanel>
                    </Grid>

                    <!-- Versions popup trigger -->
                    <Border Grid.Row="3" Padding="10,4,10,10">
                      <Button HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Left"
                              Padding="8,6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="&#x25BD;" FontSize="11" VerticalAlignment="Center" Opacity="0.7"/>
                          <TextBlock Text="{Binding VersionCountLabel}" VerticalAlignment="Center"/>
                          <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.4" Margin="4,0"/>
                          <TextBlock Text="{Binding SelectedVersionSummary}" VerticalAlignment="Center" Opacity="0.7" FontSize="11"/>
                        </StackPanel>
                        <Button.Flyout>
                          <Flyout Placement="Bottom">
                            <Border Background="#222" Padding="8" MinWidth="320" MaxHeight="380">
                              <Grid RowDefinitions="Auto,Auto,*">
                                <TextBlock Grid.Row="0"
                                           Text="Pick versions to download"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                                  <Button Content="Select all"
                                          Padding="6,2"
                                          FontSize="11"
                                          Command="{Binding SelectAllVersionsCommand}"/>
                                  <Button Content="Latest only"
                                          Padding="6,2"
                                          FontSize="11"
                                          Command="{Binding LatestVersionOnlyCommand}"/>
                                  <Button Content="Add all to queue"
                                          Padding="6,2"
                                          FontSize="11"
                                          Classes="accent"
                                          Command="{Binding EnqueueAllVersionsCommand}"
                                          ToolTip.Tip="Enqueue every version of this model immediately"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                  <ItemsControl ItemsSource="{Binding Versions}">
                                    <ItemsControl.ItemTemplate>
                                      <DataTemplate x:DataType="vm:CivitaiVersionPickItemViewModel">
                                        <Border Padding="4" Margin="0,2">
                                          <Grid ColumnDefinitions="Auto,*,Auto">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1">
                                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                              <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding BaseModel}" Opacity="0.6" FontSize="11"/>
                                                <TextBlock Text="·" Opacity="0.4" FontSize="11"/>
                                                <TextBlock Text="{Binding SizeDisplay}" Opacity="0.6" FontSize="11"/>
                                              </StackPanel>
                                            </StackPanel>
                                            <Border Grid.Column="2"
                                                    IsVisible="{Binding IsEarlyAccess}"
                                                    Background="#669333EA"
                                                    CornerRadius="3"
                                                    Padding="4,1"
                                                    VerticalAlignment="Center">
                                              <TextBlock Text="EA" FontSize="9" Foreground="White"/>
                                            </Border>
                                          </Grid>
                                        </Border>
                                      </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                  </ItemsControl>
                                </ScrollViewer>
                              </Grid>
                            </Border>
                          </Flyout>
                        </Button.Flyout>
                      </Button>
                    </Border>

                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

      <!-- Sticky Load-more footer — centered pill, not a full-width action bar. -->
      <Border Grid.Row="1"
              Background="Transparent"
              Padding="12,8"
              IsVisible="{Binding HasMore}">
        <Button Content="Load more"
                Command="{Binding LoadMoreCommand}"
                HorizontalAlignment="Center"
                Padding="20,6"
                FontSize="12"
                Classes="accent"/>
      </Border>

      </Grid>

      <!-- Queue panel -->
      <Border Grid.Column="1"
              Width="340"
              IsVisible="{Binding IsQueuePanelOpen}"
              Background="#161616"
              BorderBrush="#2A2A2A"
              BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,*,Auto">

          <Border Grid.Row="0" Padding="12,10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="Download Queue" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Content="Start"
                        Command="{Binding StartQueueCommand}"
                        Padding="8,4"
                        Classes="accent"/>
                <Button Content="Clear done"
                        Command="{Binding ClearCompletedCommand}"
                        Padding="8,4"
                        ToolTip.Tip="Remove completed jobs from the list"/>
                <Button Content="Clear all"
                        Command="{Binding ClearQueueCommand}"
                        Padding="8,4"
                        Foreground="#F87171"
                        ToolTip.Tip="Remove every job (in-progress downloads are cancelled)"/>
              </StackPanel>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="1" Padding="8">
            <ItemsControl ItemsSource="{Binding Queue.Jobs}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="svc:CivitaiDownloadJob">
                  <Border Margin="2" Padding="8" Background="#1E1E1E" CornerRadius="4">
                    <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Row="0" Grid.Column="0"
                                 Text="{Binding ModelName}"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis"/>
                      <Button Grid.Row="0" Grid.Column="1"
                              Content="&#x2715;"
                              Padding="6,0"
                              FontSize="10"
                              Command="{Binding $parent[UserControl].((vm:CivitaiBrowserViewModel)DataContext).RemoveJobCommand}"
                              CommandParameter="{Binding}"/>
                      <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding VersionName}" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="·" Opacity="0.4" FontSize="11"/>
                        <TextBlock Text="{Binding BaseModel}" Opacity="0.6" FontSize="11"/>
                        <TextBlock Text="·" Opacity="0.4" FontSize="11"/>
                        <TextBlock Text="{Binding SizeDisplay}" Opacity="0.6" FontSize="11"/>
                      </StackPanel>
                      <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                        <ProgressBar Grid.Column="0" Value="{Binding ProgressPercent}" Maximum="100" Height="6"/>
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" FontSize="10" Opacity="0.7" Margin="8,0,0,0"/>
                      </Grid>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="2" Padding="12,8" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0">
            <TextBlock Opacity="0.7" FontSize="11">
              <Run Text="Queued: "/><Run Text="{Binding Queue.ActiveCount}"/>
              <Run Text=" · Done: "/><Run Text="{Binding Queue.CompletedCount}"/>
              <Run Text=" · Errors: "/><Run Text="{Binding Queue.ErrorCount}"/>
            </TextBlock>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <!-- Status -->
    <Border Grid.Row="3" Background="#1A1A1A" Padding="12,6" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0"
            IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <TextBlock Text="{Binding StatusMessage}" Opacity="0.8" FontSize="12"/>
    </Border>

  </Grid>
</UserControl>
