#!/bin/sh
# Enforces branch naming convention and blocks direct pushes to protected branches.
# Allowed patterns: main, develop, feature/*, bug/*, hotfix/*, release/*
# Protected branches (require PR): main, develop

branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

# Block direct pushes to protected branches
if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
  echo ""
  echo "  ERROR: Direct push to '$branch' is not allowed."
  echo "  Please create a feature branch and submit a pull request."
  echo ""
  exit 1
fi

valid_pattern='^(main|develop|feature/.+|bug/.+|hotfix/.+|release/.+)$'

if ! echo "$branch" | grep -qE "$valid_pattern"; then
  echo ""
  echo "  ERROR: Branch name '$branch' does not follow the naming convention."
  echo ""
  echo "  Allowed prefixes:"
  echo "    main"
  echo "    develop"
  echo "    feature/<name>    e.g. feature/wizard-ui"
  echo "    bug/<name>        e.g. bug/taskbar-null-ref"
  echo "    hotfix/<name>     e.g. hotfix/crash-on-install"
  echo "    release/<version> e.g. release/1.3.0"
  echo ""
  echo "  Rename your branch first:"
  echo "    git branch -m $branch <correct-name>"
  echo ""
  exit 1
fi

exit 0
